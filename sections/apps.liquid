<div class="{% if section.settings.show_space %}fully-spaced-row--medium{% endif %}" style="position:relative;overflow:hidden;{% if section.settings.bg_color != blank and section.settings.bg_color != 'rgba(0,0,0,0)' %}background-color:{{ section.settings.bg_color }};{% endif %}">
  {%- if section.settings.bg_video != blank -%}
    <video style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0" autoplay muted loop playsinline>
      {%- for source in section.settings.bg_video.sources -%}
        <source src="{{ source.url }}" type="{{ source.mime_type }}">
      {%- endfor -%}
    </video>
  {%- elsif section.settings.bg_image != blank -%}
    <div style="position:absolute;inset:0;width:100%;height:100%;background:url({{ section.settings.bg_image | image_url: width: 1920 }}) center/cover no-repeat;z-index:0"></div>
  {%- endif -%}
  <div style="position:relative;z-index:1">
    {%- unless section.settings.full_width -%}<div class="container">{%- endunless -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hometitle h4 align-center" style="margin-bottom: 8px">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="align-center" style="margin-bottom: 32px; color: #666">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      {%- for block in section.blocks -%}
        {% render block %}
      {%- endfor -%}
    {%- unless section.settings.full_width -%}</div>{%- endunless -%}
  </div>
</div>

{% schema %}
{
  "name": "Apps",
  "class": "section-apps",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Wide display",
      "default": false
    },
    {
      "id": "show_space",
      "type": "checkbox",
      "label": "Show space above and below section",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "video",
      "id": "bg_video",
      "label": "Background video"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Apps"
    }
  ]
}
{% endschema %}