{%- comment -%} Drink LLC — Brand Statement Section {%- endcomment -%}

<section class="section brand-statement bg-carbon">
  <div class="container text-center">
    <h2 class="brand-statement__heading">{{ section.settings.heading | default: 'Not a Supplement Brand' }}</h2>
    <p class="brand-statement__body">{{ section.settings.body | default: 'We make drinks. Electrolytes. B-vitamins. No caffeine. No sugar. That is it.' }}</p>
  </div>
</section>

<style>
  .brand-statement {
    padding: var(--space-3xl) 0;
  }

  .brand-statement__heading {
    margin-bottom: var(--space-lg);
  }

  .brand-statement__body {
    font-size: 1.15rem;
    max-width: 50ch;
    margin: 0 auto;
    line-height: 1.8;
  }
</style>

{% schema %}
{
  "name": "Brand Statement",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not a Supplement Brand"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "We make drinks. Electrolytes. B-vitamins. No caffeine. No sugar. That is it."
    }
  ],
  "presets": [
    {
      "name": "Brand Statement"
    }
  ]
}
{% endschema %}
