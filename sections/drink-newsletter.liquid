{%- style -%}
  .drink-newsletter {
    background-color: {{ section.settings.background_color | default: '#1d1d1d' }};
    {% if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' %}
      color: {{ section.settings.text_color }};
    {% endif %}
    {% if section.settings.background_image != blank %}
      background-image: url({{ section.settings.background_image | image_url: width: 1920 }});
      background-size: cover;
      background-position: center;
    {% endif %}
  }
  {% if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' %}
    .drink-newsletter h2 {
      color: {{ section.settings.text_color }};
    }
  {% endif %}
  {% if section.settings.button_bg != blank and section.settings.button_bg != 'rgba(0,0,0,0)' %}
    .drink-newsletter button[type="submit"] {
      background-color: {{ section.settings.button_bg }};
    }
  {% endif %}
  {% if section.settings.button_color != blank and section.settings.button_color != 'rgba(0,0,0,0)' %}
    .drink-newsletter button[type="submit"] {
      color: {{ section.settings.button_color }};
    }
  {% endif %}
  .drink-newsletter-section {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  @media screen and (min-width: 768px) {
    .drink-newsletter-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="drink-newsletter">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'heading' -%}
        {%- if block.settings.heading != blank -%}
          <h2 {{ block.shopify_attributes }}>{{ block.settings.heading }}</h2>
        {%- endif -%}

      {%- when 'subtitle' -%}
        {%- if block.settings.text != blank -%}
          <p class="drink-newsletter__subtitle" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
        {%- endif -%}

      {%- when 'email_form' -%}
        <div {{ block.shopify_attributes }}>
          {%- form 'customer', id: 'DrinkNewsletter', class: 'drink-newsletter__form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input
              id="DrinkNewsletterEmail--{{ section.id }}"
              type="email"
              name="contact[email]"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
                aria-describedby="DrinkNewsletter-error"
              {% elsif form.posted_successfully? %}
                aria-describedby="DrinkNewsletter-success"
              {% endif %}
              placeholder="{{ section.settings.input_placeholder | default: 'Enter your email' }}"
              required
            >
            <button type="submit">{{ section.settings.button_label | default: 'Subscribe' }}</button>
          {%- endform -%}

          {%- if form.errors -%}
            <p class="drink-newsletter__message drink-newsletter__message--error" id="DrinkNewsletter-error">
              {{ form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email }}
            </p>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <p class="drink-newsletter__message drink-newsletter__message--success" id="DrinkNewsletter-success">
              {{ 'newsletter.success' | t }}
            </p>
          {%- endif -%}
        </div>
    {%- endcase -%}
  {%- endfor -%}

  {%- if section.settings.privacy_text != blank -%}
    <p class="drink-newsletter__privacy">{{ section.settings.privacy_text }}</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Drink Newsletter",
  "tag": "section",
  "class": "drink-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Count Me In"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy disclaimer",
      "default": "No spam. No nonsense. Unsubscribe whenever."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1d1d1d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#7CB518"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button text color",
      "default": "#1d1d1d"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 52,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Stay in the Loop"
        }
      ]
    },
    {
      "type": "subtitle",
      "name": "Subtitle",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subtitle text",
          "default": "Get 10% off your first order, plus recipes, wellness inspo, and first dibs on new drops."
        }
      ]
    },
    {
      "type": "email_form",
      "name": "Email form",
      "limit": 1,
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "Drink Newsletter",
      "blocks": [
        { "type": "heading" },
        { "type": "subtitle" },
        { "type": "email_form" }
      ]
    }
  ]
}
{% endschema %}
