<!-- Drink Accessories Section — Shopify Custom Liquid with Theme Customizer editability -->
<!-- 4-card accessory grid + highlight callout section -->
<style>
.drink-accessories {
  padding: 120px 48px;
  background: #F8F8F8;
  font-family: var(--base-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}
.drink-accessories-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0;
}
.drink-accessories-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.drink-accessories-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
}
.drink-accessories > *:not(.drink-accessories-bg):not(.drink-accessories-overlay) {
  position: relative;
  z-index: 2;
}
.drink-accessories * { box-sizing: border-box; margin: 0; padding: 0; }
.drink-acc-header {
  text-align: center;
  margin-bottom: 32px;
}
.drink-acc-eyebrow {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #777777;
  margin-bottom: 16px;
}
.drink-acc-header h2 {
  font-family: var(--heading-font-family), serif;
  font-size: 56px;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.1;
}
.drink-acc-intro {
  max-width: 700px;
  margin: 0 auto 64px;
  text-align: center;
  font-size: 18px;
  line-height: 1.7;
  color: #555555;
}
.drink-acc-intro strong { color: #1A1A1A; }
.drink-acc-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  max-width: 1300px;
  margin: 0 auto 48px;
}
.drink-acc-card {
  border-radius: 16px;
  overflow: hidden;
  background: #FFFFFF;
  cursor: pointer;
  transition: transform 0.3s;
  border: 1px solid #EEEEEE;
  display: flex;
  flex-direction: column;
}
.drink-acc-card:hover { transform: translateY(-4px); }
.drink-acc-card a.drink-acc-card-link {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
  text-decoration: none;
  color: inherit;
}
.drink-acc-card-img {
  width: 100%;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #F5F5F5 0%, #FFFFFF 100%);
}
.drink-acc-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.drink-acc-card-label {
  padding: 16px 20px;
  background: #FFFFFF;
  color: #1A1A1A;
}
.drink-acc-card-label h4 { font-size: 18px; font-weight: 700; margin-bottom: 2px; color: #1A1A1A; }
.drink-acc-card-label p { font-size: 14px; color: #555555; }
.drink-acc-highlight {
  max-width: 1300px;
  margin: 0 auto;
  background: #FFF8E1;
  border-radius: 20px;
  padding: 64px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
}
.drink-acc-highlight-visual {
  border-radius: 12px;
  overflow: hidden;
}
.drink-acc-highlight-visual img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 12px;
}
.drink-acc-highlight h3 {
  font-family: var(--heading-font-family), serif;
  font-size: 36px;
  font-weight: 700;
  margin-bottom: 16px;
  line-height: 1.2;
  color: #1A1A1A;
}
.drink-acc-highlight p {
  font-size: 17px;
  line-height: 1.7;
  color: #555555;
  margin-bottom: 24px;
}
.drink-acc-highlight .drink-btn-acc {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: #1A1A1A;
  color: #FFFFFF;
  padding: 16px 32px;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 700;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: all 0.25s;
}
.drink-acc-highlight .drink-btn-acc:hover {
  background: #333333;
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}

/* Tablet */
@media (max-width: 1024px) {
  .drink-acc-grid { grid-template-columns: repeat(2, 1fr); }
  .drink-acc-highlight { grid-template-columns: 1fr; padding: 40px; }
  .drink-acc-header h2 { font-size: 40px; }
}
/* Mobile */
@media (max-width: 768px) {
  .drink-accessories { padding: 64px 20px; }
  .drink-acc-header h2 { font-size: 32px; }
  .drink-acc-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
  .drink-acc-intro { font-size: 15px; margin-bottom: 40px; padding: 0; }
  .drink-acc-highlight { padding: 24px; gap: 24px; border-radius: 16px; }
  .drink-acc-highlight h3 { font-size: 26px; }
  .drink-acc-highlight p { font-size: 15px; }
  .drink-acc-card-label h4 { font-size: 15px; }
  .drink-acc-card-label p { font-size: 12px; }
  .drink-acc-card-label { padding: 14px; }
}
@media (max-width: 480px) {
  .drink-acc-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
  .drink-acc-highlight h3 { font-size: 22px; }
  .drink-acc-header h2 { font-size: 28px; }
}
</style>

<section class="drink-accessories">
  {% if section.settings.bg_image != blank %}
    <div class="drink-accessories-bg">
      <img src="{{ section.settings.bg_image | image_url: width: 1920 }}" alt="" width="{{ section.settings.bg_image.width }}" height="{{ section.settings.bg_image.height }}" loading="lazy">
    </div>
    <div class="drink-accessories-overlay" style="background: {{ section.settings.overlay_color }}"></div>
  {% endif %}
  <div class="drink-acc-header">
    <div class="drink-acc-eyebrow">{{ section.settings.eyebrow }}</div>
    <h2>{{ section.settings.heading }}</h2>
  </div>
  <div class="drink-acc-intro">
    {{ section.settings.intro_text }}
  </div>

  <div class="drink-acc-grid">
    {% for block in section.blocks %}
      <div class="drink-acc-card" {{ block.shopify_attributes }}>
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="drink-acc-card-link">
        {% endif %}
          <div class="drink-acc-card-img">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.name }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="lazy">
            {% endif %}
          </div>
          <div class="drink-acc-card-label">
            <h4>{{ block.settings.name }}</h4>
            <p>{{ block.settings.description }}</p>
          </div>
        {% if block.settings.link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <!-- Highlight callout -->
  <div class="drink-acc-highlight">
    <div class="drink-acc-highlight-visual">
      {% if section.settings.highlight_image != blank %}
        <img src="{{ section.settings.highlight_image | image_url: width: 800 }}" alt="{{ section.settings.highlight_heading }}" width="{{ section.settings.highlight_image.width }}" height="{{ section.settings.highlight_image.height }}" loading="lazy">
      {% endif %}
    </div>
    <div>
      <h3>{{ section.settings.highlight_heading }}</h3>
      <p>{{ section.settings.highlight_description }}</p>
      {% if section.settings.highlight_button_label != blank %}
        <a href="{{ section.settings.highlight_button_url }}" class="drink-btn-acc">{{ section.settings.highlight_button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Drink Accessories",
  "class": "section-drink-accessories",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Bundles"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More ways to drink."
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro Text",
      "default": "<p>Bundles, variety packs, and gear. <strong>Everything you need to stay hydrated.</strong></p>"
    },
    {
      "type": "image_picker",
      "id": "highlight_image",
      "label": "Highlight Image"
    },
    {
      "type": "text",
      "id": "highlight_heading",
      "label": "Highlight Heading",
      "default": "Try all five. Decide later."
    },
    {
      "type": "textarea",
      "id": "highlight_description",
      "label": "Highlight Description",
      "default": "The 5-Flavor Bundle gives you one tub of each flavor. 150 servings total. No commitment, no guessing."
    },
    {
      "type": "text",
      "id": "highlight_button_label",
      "label": "Highlight Button Label",
      "default": "Shop All Bundles"
    },
    {
      "type": "url",
      "id": "highlight_button_url",
      "label": "Highlight Button URL"
    },
    {
      "type": "header",
      "content": "Section Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color_background",
      "id": "overlay_color",
      "label": "Overlay Color",
      "info": "Semi-transparent overlay on top of the background image.",
      "default": "rgba(13,13,13,0.9)"
    }
  ],
  "blocks": [
    {
      "type": "accessory",
      "name": "Accessory",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Accessory Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Accessory Name",
          "default": "Accessory"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Accessory description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Drink Accessories",
      "settings": {
        "eyebrow": "Bundles",
        "heading": "More ways to drink.",
        "intro_text": "<p>Bundles, variety packs, and gear. <strong>Everything you need to stay hydrated.<\/strong><\/p>",
        "highlight_heading": "Try all five. Decide later.",
        "highlight_description": "The 5-Flavor Bundle gives you one tub of each flavor. 150 servings total. No commitment, no guessing.",
        "highlight_button_label": "Shop All Bundles",
        "highlight_button_url": "/collections/bundles"
      },
      "blocks": [
        {
          "type": "accessory",
          "settings": {
            "name": "Variety Pack",
            "description": "All five flavors. 5 single-serve sticks."
          }
        },
        {
          "type": "accessory",
          "settings": {
            "name": "Starter Kit",
            "description": "One tub + shaker bottle. Pick your flavor."
          }
        },
        {
          "type": "accessory",
          "settings": {
            "name": "Shaker Bottle",
            "description": "BPA-free. 20oz. Gets the job done."
          }
        },
        {
          "type": "accessory",
          "settings": {
            "name": "5-Flavor Bundle",
            "description": "One tub of each. 150 servings total."
          }
        }
      ]
