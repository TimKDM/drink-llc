<!-- Drink About Us Section -->
<style>
.drink-about {
  padding: 120px 48px;
  background: #ECEAE4;
  position: relative;
  overflow: hidden;
  font-family: var(--base-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  box-sizing: border-box;
}
.drink-about * { box-sizing: border-box; margin: 0; padding: 0; }
.drink-about::before {
  content: '';
  position: absolute;
  top: -120px; right: -120px;
  width: 460px; height: 460px;
  background: radial-gradient(circle, rgba(30,127,255,0.12) 0%, transparent 70%);
  border-radius: 50%;
}
.drink-about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  max-width: 1300px;
  margin: 0 auto;
  position: relative;
}
.drink-about-img {
  width: 100%;
  border-radius: 8px;
  overflow: hidden;
  aspect-ratio: 4/3;
  position: relative;
  border: 1px solid #D8D5CD;
}
.drink-about-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: 8px;
}
.drink-about-eyebrow {
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #0B0B0F;
  margin-bottom: 16px;
  text-align: left;
}
.drink-about-content h2 {
  font-family: var(--heading-font-family), serif;
  font-size: clamp(34px, 5vw, 64px);
  font-weight: 700;
  line-height: 0.98;
  letter-spacing: -0.5px;
  text-transform: uppercase;
  margin-bottom: 24px;
  color: #0B0B0F;
}
.drink-about-content h2::after {
  content: '';
  display: block;
  width: 64px;
  height: 4px;
  margin-top: 18px;
  background: #0B0B0F;
}
.drink-about-content p {
  font-size: 18px;
  line-height: 1.7;
  color: #3A3A40;
  margin-bottom: 20px;
}
.drink-about-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin: 36px 0;
  padding: 32px 0;
  border-top: 1px solid #D8D5CD;
  border-bottom: 1px solid #D8D5CD;
}
.drink-stat-number {
  font-family: var(--heading-font-family), serif;
  font-size: clamp(48px, 6vw, 72px);
  font-weight: 800;
  letter-spacing: -1px;
  color: #0B0B0F;
  line-height: 0.9;
}
.drink-stat-label {
  font-size: 13px;
  color: #3A3A40;
  margin-top: 8px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
}
.drink-about .drink-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #0B0B0F;
  color: #FFFFFF;
  padding: 16px 34px;
  border-radius: 4px;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.25s;
}
.drink-about .drink-btn:hover {
  background: #0B0B0F;
  transform: translateY(-2px);
}
@media (max-width: 1024px) {
  .drink-about-grid { grid-template-columns: 1fr; gap: 48px; }
}
@media (max-width: 768px) {
  .drink-about { padding: 64px 20px; }
  .drink-about-grid { gap: 40px; }
  .drink-about-content p { font-size: 16px; }
  .drink-about-stats { grid-template-columns: repeat(3, 1fr); gap: 16px; padding: 24px 0; }
  .drink-stat-number { font-size: clamp(34px, 9vw, 48px); }
  .drink-stat-label { font-size: 11px; }
}
@media (max-width: 480px) {
  .drink-about-stats { gap: 8px; }
  .drink-stat-number { font-size: 30px; }
  .drink-stat-label { font-size: 10px; letter-spacing: 1px; }
}
</style>

<section class="drink-about">
  <div class="drink-about-grid">
    <div class="drink-about-img">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.image.alt | default: section.settings.heading }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="lazy">
      {% endif %}
    </div>
    <div class="drink-about-content">
      <div class="drink-about-eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description_1 }}</p>
      <p>{{ section.settings.description_2 }}</p>
      <div class="drink-about-stats">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <div {{ block.shopify_attributes }}>
              <div class="drink-stat-number">{{ block.settings.number }}</div>
              <div class="drink-stat-label">{{ block.settings.label }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_url }}" class="drink-btn">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Drink About Us",
  "class": "section-drink-about-us",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "About DRiNK"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We make hydration powder."
    },
    {
      "type": "textarea",
      "id": "description_1",
      "label": "Description (Paragraph 1)",
      "default": "Electrolytes. B-vitamins. Five flavors. No sugar, no caffeine, no fillers. Just mix it with water and move on."
    },
    {
      "type": "textarea",
      "id": "description_2",
      "label": "Description (Paragraph 2)",
      "default": "Every tub has 30 servings. Every serving has the same clean formula. We kept it simple because hydration should be."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop All Flavors"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "100+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Stat Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Drink About Us",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "number": "5",
            "label": "Flavors"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "0g",
            "label": "Sugar"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "6",
            "label": "Electrolytes"
          }
        }
      ]
    }
  ]
}
{% endschema %}
