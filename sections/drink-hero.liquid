{%- style -%}
  #shopify-section-{{ section.id }} {
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  {% if section.settings.image_height != blank and section.settings.image_height != 0 %}
    #shopify-section-{{ section.id }} .drink-hero,
    #shopify-section-{{ section.id }} .drink-hero__content {
      min-height: {{ section.settings.image_height }}vh;
    }
  {% endif %}
  {% if section.settings.overlay_opacity != blank %}
    #shopify-section-{{ section.id }} .drink-hero::after {
      opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    }
  {% endif %}
{%- endstyle -%}

<section class="drink-hero">
  {%- if section.settings.video_url != blank -%}
    {%- assign hero_autoplay = section.settings.autoplay -%}
    {%- assign hero_loop = section.settings.loop -%}
    {%- assign hero_muted = section.settings.muted -%}
    <div class="drink-hero__image drink-hero__image--video">
      {{
        section.settings.video_url
        | external_video_url: autoplay: hero_autoplay, loop: hero_loop, muted: hero_muted
        | external_video_tag: loading: 'lazy'
      }}
    </div>
  {%- else -%}
    <div class="drink-hero__image">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            loading: 'eager',
            widths: '375, 550, 750, 1000, 1200',
            sizes: '100vw'
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="drink-hero__content items-center">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'badge' -%}
          {%- if block.settings.text != blank -%}
            <span class="drink-mono-label" style="background: #fff; border-color: var(--drink-sepia); color: var(--drink-rust);" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {%- endif -%}

        {%- when 'heading' -%}
          <h1 style="font-family: var(--font-heading); font-size: 4.5rem; text-transform: none; letter-spacing: -0.02em;" {{ block.shopify_attributes }}>{{ section.settings.heading }}</h1>

        {%- when 'subtitle' -%}
          {%- if section.settings.subtitle != blank -%}
            <p class="drink-hero__subtitle" style="font-family: var(--font-body); font-size: 1.1rem; max-width: 600px;" {{ block.shopify_attributes }}>{{ section.settings.subtitle }}</p>
          {%- endif -%}

        {%- when 'buttons' -%}
          <div class="drink-hero__cta" {{ block.shopify_attributes }}>
            {%- if block.settings.button_label_1 != blank -%}
              <a href="{{ block.settings.button_link_1 }}" class="drink-btn drink-btn-primary" style="{% if block.settings.btn1_bg != blank and block.settings.btn1_bg != 'rgba(0,0,0,0)' %}background:{{ block.settings.btn1_bg }};{% endif %}{% if block.settings.btn1_color != blank and block.settings.btn1_color != 'rgba(0,0,0,0)' %}color:{{ block.settings.btn1_color }};{% endif %}">
                {{ block.settings.button_label_1 }}
              </a>
            {%- endif -%}
            {%- if block.settings.button_label_2 != blank -%}
              <a href="{{ block.settings.button_link_2 }}" class="drink-btn drink-btn-secondary" style="{% if block.settings.btn2_color != blank and block.settings.btn2_color != 'rgba(0,0,0,0)' %}color:{{ block.settings.btn2_color }};border-color:{{ block.settings.btn2_color }};{% endif %}">
                {{ block.settings.button_label_2 }}
              </a>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Drink Hero",
  "tag": "section",
  "class": "drink-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Hero height (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "default": 70,
      "unit": "vh"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL (YouTube or Vimeo)",
      "accept": ["youtube", "vimeo"],
      "info": "When set, the video replaces the hero image."
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Muted",
      "default": true,
      "info": "Video must be muted to autoplay on most browsers."
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>What You Put In <em>Matters</em>.</p>"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Organic teas, matcha, superfoods, and spices — sourced from farms we trust, tested with precision, and crafted for people who believe what goes in matters."
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Gradient overlay strength",
      "info": "Controls how dark the gradient is over the image for text readability",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "Where Purity Meets Performance · Organic · Lab-Tested · No Fillers"
        },
        {
          "type": "color",
          "id": "badge_bg",
          "label": "Badge background"
        },
        {
          "type": "color",
          "id": "badge_color",
          "label": "Badge text color"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": []
    },
    {
      "type": "subtitle",
      "name": "Subtitle",
      "limit": 1,
      "settings": []
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "label": "Primary button label",
          "default": "Shop Best Sellers"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Primary button link"
        },
        {
          "type": "color",
          "id": "btn1_bg",
          "label": "Primary button background"
        },
        {
          "type": "color",
          "id": "btn1_color",
          "label": "Primary button text color"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Secondary button label",
          "default": "Go Wholesale"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Secondary button link"
        },
        {
          "type": "color",
          "id": "btn2_color",
          "label": "Secondary button color"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Drink Hero",
      "blocks": [
        { "type": "badge" },
        { "type": "heading" },
        { "type": "subtitle" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
