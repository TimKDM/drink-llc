{%- style -%}
  .drink-contact-page {
    font-family: 'Jost', var(--font-body-family), sans-serif;
  }

  /* Hero */
  .drink-contact-hero {
    background: linear-gradient(135deg, #f5f2f6 0%, #ebe5ed 100%);
    padding: 64px 24px;
    text-align: center;
  }
  .drink-contact-hero__label {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-dark, #9b76a7);
    margin-bottom: 12px;
    display: block;
  }
  .drink-contact-hero h1 {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 16px;
    margin-top: 0;
    letter-spacing: -0.01em;
  }
  .drink-contact-hero h1 strong {
    font-weight: 600;
  }
  .drink-contact-hero p {
    font-size: 17px;
    color: var(--color-text-muted, #7a6f64);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Contact Grid */
  .drink-contact-body {
    padding: 64px 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .drink-contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  @media screen and (min-width: 768px) {
    .drink-contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: start;
    }
  }

  /* Contact Info */
  .drink-contact-info h2 {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: 28px;
    font-weight: 400;
    margin-bottom: 16px;
    margin-top: 0;
    letter-spacing: -0.01em;
  }
  .drink-contact-info > p {
    font-size: 16px;
    color: var(--color-text-muted, #7a6f64);
    margin-bottom: 36px;
    line-height: 1.7;
  }
  .drink-contact-methods {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .drink-contact-method {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .drink-contact-method__icon {
    width: 44px;
    height: 44px;
    min-width: 44px;
    background: #f0ebf4;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .drink-contact-method__icon svg {
    width: 20px;
    height: 20px;
    stroke: var(--color-accent-dark, #9b76a7);
    stroke-width: 1.5;
    fill: none;
  }
  .drink-contact-method h4 {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 4px;
    margin-top: 0;
  }
  .drink-contact-method p {
    font-size: 14px;
    color: var(--color-text-muted, #7a6f64);
    margin: 0;
    line-height: 1.5;
  }
  .drink-contact-method a {
    color: var(--color-accent-dark, #9b76a7);
    text-decoration: none;
  }
  .drink-contact-method a:hover {
    text-decoration: underline;
  }

  /* Contact Form Card */
  .drink-contact-form-card {
    background: var(--color-background-hex, #ffffff);
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 4px 32px rgba(0,0,0,0.07);
    border: 1px solid var(--color-border-hex, #d2c4d7);
  }
  @media screen and (max-width: 767px) {
    .drink-contact-form-card {
      padding: 24px;
    }
  }
  .drink-contact-form-card h3 {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 28px;
    margin-top: 0;
    letter-spacing: 0.02em;
  }
  /* Form fields — stack with vertical gaps */
  .drink-contact-form-card .field {
    display: flex;
    flex-direction: column;
    margin-bottom: 20px;
    position: relative;
  }
  .drink-contact-form-card .field__label,
  .drink-contact-form-card .form__label {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
    order: -1;
    position: static;
    pointer-events: auto;
    color: rgba(var(--color-foreground));
  }
  .drink-contact-form-card .field__input,
  .drink-contact-form-card .text-area {
    width: 100%;
    padding: 12px 16px;
    font-size: 15px;
    font-family: 'Jost', var(--font-body-family), sans-serif;
    border: 1px solid rgba(var(--color-base-border-1));
    border-radius: 6px;
    background: transparent;
    color: rgb(var(--color-foreground));
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
  }
  .drink-contact-form-card .select__select {
    width: 100%;
    padding: 12px 16px;
    font-size: 15px;
    font-family: 'Jost', var(--font-body-family), sans-serif;
    border: 1px solid rgba(var(--color-base-border-1));
    border-radius: 6px;
    background: transparent;
    color: rgb(var(--color-foreground));
    cursor: pointer;
    margin: 0;
  }
  .drink-contact-form-card .field__input:focus,
  .drink-contact-form-card .text-area:focus,
  .drink-contact-form-card .select__select:focus {
    border-color: var(--color-accent-dark, #9b76a7);
    outline: none;
    box-shadow: 0 0 0 3px rgba(155, 118, 167, 0.12);
  }
  .drink-contact-form-card .field:before,
  .drink-contact-form-card .field:after {
    content: none;
  }
  .drink-contact-submit {
    width: 100%;
    margin-top: 8px;
  }

  /* Quick Help Section */
  .drink-contact-quick {
    background: linear-gradient(135deg, #f0ebf2 0%, #e8e0ec 100%);
    padding: 64px 24px;
  }
  .drink-contact-quick .drink-section-header {
    margin-bottom: 40px;
  }
  .drink-quick-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 900px;
    margin: 0 auto;
  }
  @media screen and (min-width: 768px) {
    .drink-quick-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .drink-quick-card {
    background: var(--color-background-hex, #ffffff);
    border-radius: 10px;
    padding: 28px 24px;
    text-align: center;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border-hex, #d2c4d7);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
    display: block;
  }
  .drink-quick-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .drink-quick-card__icon {
    width: 48px;
    height: 48px;
    background: #f0ebf4;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
  }
  .drink-quick-card__icon svg {
    width: 22px;
    height: 22px;
    stroke: var(--color-accent-dark, #9b76a7);
    stroke-width: 1.5;
    fill: none;
  }
  .drink-quick-card h3 {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
    margin-top: 0;
  }
  .drink-quick-card p {
    font-size: 14px;
    color: var(--color-text-muted, #7a6f64);
    margin: 0;
    line-height: 1.5;
  }

  /* CTA */
  .drink-contact-cta {
    background: #2c2420;
    color: #fff;
    padding: 64px 24px;
    text-align: center;
  }
  .drink-contact-cta h2 {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: clamp(22px, 4vw, 30px);
    font-weight: 400;
    margin-bottom: 12px;
    margin-top: 0;
    color: #fff;
  }
  .drink-contact-cta p {
    color: rgba(255,255,255,0.7);
    margin-bottom: 28px;
    font-size: 16px;
  }
  .drink-contact-cta .drink-btn-accent {
    background: var(--color-accent-hex, #c8a8d8);
    color: var(--color-foreground-hex, #1d1917);
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 14px 32px;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .drink-contact-cta .drink-btn-accent:hover {
    background: #b899c5;
  }
{%- endstyle -%}

<div class="drink-contact-page">

  {%- comment -%} Hero {%- endcomment -%}
  <div class="drink-contact-hero">
    <span class="drink-contact-hero__label">{{ section.settings.hero_label }}</span>
    <h1>{{ section.settings.hero_heading }}</h1>
    <p>{{ section.settings.hero_subtext }}</p>
  </div>

  {%- comment -%} Contact Grid {%- endcomment -%}
  <div class="drink-contact-body">
    <div class="drink-contact-grid">

      {%- comment -%} Left: Contact Info {%- endcomment -%}
      <div class="drink-contact-info">
        <h2>{{ section.settings.info_heading }}</h2>
        <p>{{ section.settings.info_text }}</p>

        <div class="drink-contact-methods">
          {%- if section.settings.email_address != blank -%}
            <div class="drink-contact-method">
              <div class="drink-contact-method__icon">
                <svg viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <h4>Email Us</h4>
                <p><a href="mailto:{{ section.settings.email_address }}">{{ section.settings.email_address }}</a></p>
                <p>{{ section.settings.email_response_time }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- if section.settings.phone_number != blank -%}
            <div class="drink-contact-method">
              <div class="drink-contact-method__icon">
                <svg viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <h4>Call Us</h4>
                <p><a href="tel:{{ section.settings.phone_number }}">{{ section.settings.phone_number }}</a></p>
                <p>{{ section.settings.phone_hours }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- if section.settings.show_location and section.settings.location_address != blank -%}
            <div class="drink-contact-method">
              <div class="drink-contact-method__icon">
                <svg viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <h4>Location</h4>
                <p>{{ section.settings.location_address }}</p>
              </div>
            </div>
          {%- endif -%}

          <div class="drink-contact-method">
            <div class="drink-contact-method__icon">
              <svg viewBox="0 0 24 24"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            </div>
            <div>
              <h4>Wholesale Inquiries</h4>
              <p>Interested in partnering with us?</p>
              <p><a href="/pages/wholesale">Apply for a wholesale account →</a></p>
            </div>
          </div>
        </div>
      </div>

      {%- comment -%} Right: Contact Form {%- endcomment -%}
      <div class="drink-contact-form-card">
        <h3>Send Us a Message</h3>
        {%- form 'contact', id: 'ContactForm' -%}
          {%- if form.posted_successfully? -%}
            <div class="form-status form-status-list form__message" role="status">
              <h2>Thanks for reaching out — we'll be in touch within 24 hours.</h2>
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="form-status" role="alert">
              <h2>{{ 'templates.contact.form.error_heading' | t }}</h2>
              <ul>
                {%- for field in form.errors -%}
                  <li><a href="#ContactForm-{{ field }}">{{ form.errors.messages[field] }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <div class="field">
            <input class="field__input" autocomplete="name" type="text" id="ContactForm-name" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="Your name *">
            <label class="field__label" for="ContactForm-name">Name</label>
          </div>

          <div class="field">
            <input class="field__input" autocomplete="email" type="email" id="ContactForm-email" name="contact[email]" autocorrect="off" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required placeholder="your@email.com *">
            <label class="field__label" for="ContactForm-email">Email</label>
          </div>

          <div class="field">
            <select class="select__select" name="contact[subject]" id="ContactForm-subject">
              <option value="">Select a topic...</option>
              <option>Product Question</option>
              <option>Order Status</option>
              <option>Wholesale Inquiry</option>
              <option>Returns & Refunds</option>
              <option>Partnership Opportunity</option>
              <option>Other</option>
            </select>
          </div>

          <div class="field">
            <textarea class="text-area field__input" rows="5" id="ContactForm-body" name="contact[body]" placeholder="How can we help you? *">
              {%- if form.body -%}{{ form.body }}{%- endif -%}
            </textarea>
            <label class="form__label field__label" for="ContactForm-body">Message</label>
          </div>

          <button type="submit" class="button button--full-width drink-contact-submit">
            Send Message
          </button>
        {%- endform -%}
      </div>

    </div>
  </div>

  {%- comment -%} Quick Help Section {%- endcomment -%}
  <div class="drink-contact-quick">
    <div class="drink-section-header">
      <span class="drink-section-label">Quick Help</span>
      <h2 class="drink-section-title">Looking for Something Specific?</h2>
    </div>
    <div class="drink-quick-grid">
      <a href="/account/orders" class="drink-quick-card">
        <div class="drink-quick-card__icon">
          <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        </div>
        <h3>Track Your Order</h3>
        <p>Check the status of your recent order with your order number.</p>
      </a>
      <a href="/policies/shipping-policy" class="drink-quick-card">
        <div class="drink-quick-card__icon">
          <svg viewBox="0 0 24 24"><path d="M16 15v-1a4 4 0 00-4-4H8m0 0l3 3m-3-3l3-3m9 14V5a2 2 0 00-2-2H6a2 2 0 00-2 2v16l4-2 4 2 4-2 4 2z"/></svg>
        </div>
        <h3>Shipping & Returns</h3>
        <p>Learn about our shipping options and hassle-free return policy.</p>
      </a>
      <a href="/pages/faq" class="drink-quick-card">
        <div class="drink-quick-card__icon">
          <svg viewBox="0 0 24 24"><path d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3>FAQ</h3>
        <p>Find answers to commonly asked questions about our products.</p>
      </a>
    </div>
  </div>

  {%- comment -%} Wholesale CTA {%- endcomment -%}
  <div class="drink-contact-cta">
    <h2>{{ section.settings.cta_heading }}</h2>
    <p>{{ section.settings.cta_text }}</p>
    <a href="{{ section.settings.cta_link }}" class="drink-btn-accent">{{ section.settings.cta_label }}</a>
  </div>

</div>

{% schema %}
{
  "name": "Contact Us Page",
  "tag": "section",
  "class": "drink-contact-us-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_label",
      "label": "Section label",
      "default": "Say Hello"
    },
    {
      "type": "richtext",
      "id": "hero_heading",
      "label": "Heading",
      "default": "<p>We're Real People. <strong>Let's Talk.</strong></p>"
    },
    {
      "type": "text",
      "id": "hero_subtext",
      "label": "Subtext",
      "default": "Have a question about a product, an order, or a partnership idea? We'd love to hear from you — and we always respond personally."
    },
    {
      "type": "header",
      "content": "Contact Info"
    },
    {
      "type": "text",
      "id": "info_heading",
      "label": "Heading",
      "default": "Let's Connect"
    },
    {
      "type": "textarea",
      "id": "info_text",
      "label": "Description",
      "default": "Whether you're a matcha enthusiast, a café owner sourcing premium ingredients, or exploring what we can do together — reach out. We love connecting with the people who use our products."
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email address",
      "default": "hello@drinkingredients.com"
    },
    {
      "type": "text",
      "id": "email_response_time",
      "label": "Response time note",
      "default": "We get back to you within 24 hours"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number (leave blank to hide)"
    },
    {
      "type": "text",
      "id": "phone_hours",
      "label": "Phone hours",
      "default": "Mon–Fri 9am–5pm MST"
    },
    {
      "type": "checkbox",
      "id": "show_location",
      "label": "Show location",
      "default": false
    },
    {
      "type": "text",
      "id": "location_address",
      "label": "Location address"
    },
    {
      "type": "header",
      "content": "Bottom CTA"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "Heading",
      "default": "Thinking Wholesale?"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Subtext",
      "default": "We partner with cafés, brands, and producers who want premium organic ingredients at scale. Let's build something great together."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Apply for Wholesale"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Contact Us Page"
    }
  ]
}
{% endschema %}
