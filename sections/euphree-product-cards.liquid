          "settings": {
            "spec_1_value": "500W",
            "spec_1_icon": "bolt",
            "spec_2_value": "40 mi",
            "spec_2_icon": "battery",
            "spec_3_value": "54 lbs",
            "spec_3_icon": "weight",
            "category": "Lightweight",
            "name": "Solar Sparrow",
            "description": "Quiet Gates belt drive, 54 lbs, easy to lift & ride. Zero chain maintenance.",
            "sale_price": "$1,999",
            "rider_height": "Riders: 4'11\" – 5'10\"",
            "color_1": "#d4643a",
            "color_2": "#5a8a5a",
            "color_3": "#7a5aaa",
            "color_4": "#4a7ab5",
            "color_5": "#6b4a3a",
            "button_label": "Shop Solar Sparrow",
            "button_url": "/products/solar-sparrow"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "badge_text": "$500 OFF",
            "spec_1_value": "750W",
