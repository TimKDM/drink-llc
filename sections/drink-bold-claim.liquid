<!-- Drink Bold Claim Section — Fully editable via Theme Customizer -->
<style>
.drink-bold-claim {
  padding: 120px 48px;
  text-align: center;
  background: #0B0B0F;
  background-image: radial-gradient(circle at 50% 0%, rgba(198,255,26,0.10), transparent 60%);
  font-family: var(--base-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  box-sizing: border-box;
}
.drink-bold-claim * { box-sizing: border-box; margin: 0; padding: 0; }
.drink-bold-claim h2 {
  font-family: var(--heading-font-family), serif;
  font-size: clamp(44px, 7vw, 96px);
  font-weight: 700;
  line-height: 0.98;
  letter-spacing: -1px;
  text-transform: uppercase;
  max-width: 1100px;
  margin: 0 auto 28px;
  color: #FFFFFF;
}
.drink-bold-claim p {
  font-size: 20px;
  color: #C9C9CE;
  max-width: 600px;
  margin: 0 auto;
  line-height: 1.6;
}
.drink-underline-accent {
  position: relative;
  display: inline;
  color: #C6FF1A;
}
.drink-underline-accent::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 8px;
  background: #C6FF1A;
  opacity: 1;
  border-radius: 0;
}
@media (max-width: 1024px) {
  .drink-bold-claim { padding: 96px 32px; }
}
@media (max-width: 768px) {
  .drink-bold-claim { padding: 72px 20px; }
  .drink-bold-claim p { font-size: 16px; }
  .drink-underline-accent::after { height: 6px; }
}
@media (max-width: 480px) {
  .drink-bold-claim { padding: 56px 18px; }
}
</style>

<section class="drink-bold-claim">
  <h2>{{ section.settings.heading_start }} <span class="drink-underline-accent">{{ section.settings.heading_highlight }}</span> {{ section.settings.heading_end }}</h2>
  <p>{{ section.settings.subheading }}</p>
</section>

{% schema %}
{
  "name": "Drink Bold Claim",
  "class": "section-drink-bold-claim",
  "settings": [
    {
      "type": "text",
      "id": "heading_start",
      "label": "Heading Start",
      "default": "Zero sugar."
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading Highlight",
      "info": "This text will have the accent underline.",
      "default": "Zero nonsense."
    },
    {
      "type": "text",
      "id": "heading_end",
      "label": "Heading End"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Five flavors. Electrolytes. B-vitamins. That's it."
    }
  ],
  "presets": [
    {
      "name": "Drink Bold Claim",
      "settings": {
        "heading_start": "Zero sugar.",
        "heading_highlight": "Zero nonsense.",
        "heading_end": "",
        "subheading": "Five flavors. Electrolytes. B-vitamins. That's it."
      }
    }
  ]
}
{% endschema %}
