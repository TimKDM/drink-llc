<!-- Drink Bold Claim Section — Fully editable via Theme Customizer -->
<style>
.drink-bold-claim {
  padding: 100px 48px;
  text-align: center;
  background: #FFFFFF;
  font-family: var(--base-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  box-sizing: border-box;
}
.drink-bold-claim * { box-sizing: border-box; margin: 0; padding: 0; }
.drink-bold-claim h2 {
  font-family: var(--heading-font-family), serif;
  font-size: 56px;
  font-weight: 700;
  line-height: 1.15;
  max-width: 900px;
  margin: 0 auto 24px;
  color: #1A1A1A;
}
.drink-bold-claim p {
  font-size: 20px;
  color: #555555;
  max-width: 600px;
  margin: 0 auto;
  line-height: 1.6;
}
.drink-underline-accent {
  position: relative;
  display: inline;
}
.drink-underline-accent::after {
  content: '';
  position: absolute;
  bottom: 2px;
  left: 0;
  right: 0;
  height: 6px;
  background: #FFE566;
  opacity: 0.25;
  border-radius: 3px;
}
@media (max-width: 1024px) {
  .drink-bold-claim h2 { font-size: 40px; }
}
@media (max-width: 768px) {
  .drink-bold-claim { padding: 64px 20px; }
  .drink-bold-claim h2 { font-size: 28px; }
  .drink-bold-claim p { font-size: 16px; }
}
@media (max-width: 480px) {
  .drink-bold-claim h2 { font-size: 24px; }
}
</style>

<section class="drink-bold-claim">
  <h2>{{ section.settings.heading_start }} <span class="drink-underline-accent">{{ section.settings.heading_highlight }}</span> {{ section.settings.heading_end }}</h2>
  <p>{{ section.settings.subheading }}</p>
</section>

{% schema %}
{
  "name": "Drink Bold Claim",
  "class": "section-drink-bold-claim",
  "settings": [
    {
      "type": "text",
      "id": "heading_start",
      "label": "Heading Start",
      "default": "Zero sugar."
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading Highlight",
      "info": "This text will have the accent underline.",
      "default": "Zero nonsense."
    },
    {
      "type": "text",
      "id": "heading_end",
      "label": "Heading End",
      "default": "Just hydration."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Five flavors. Electrolytes. B-vitamins. That's it."
    }
  ],
  "presets": [
    {
      "name": "Drink Bold Claim",
      "settings": {
        "heading_start": "Zero sugar.",
        "heading_highlight": "Zero nonsense.",
        "heading_end": "",
        "subheading": "Five flavors. Electrolytes. B-vitamins. That's it."
      }
    }
  ]
}
{% endschema %}
