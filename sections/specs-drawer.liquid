{%- comment -%}
  Specs Drawer — Slide-in panel from right side
  Triggered by a button, displays organized spec categories
{%- endcomment -%}

<div id="SpecsDrawer-{{ section.id }}" class="specs-drawer" data-specs-drawer>
  <div class="specs-drawer__overlay" data-specs-drawer-close></div>
  <div class="specs-drawer__panel">
    <div class="specs-drawer__header">
      <h2 class="specs-drawer__title">{{ section.settings.title | default: 'Technical Specifications' }}</h2>
      <button class="specs-drawer__close" data-specs-drawer-close aria-label="Close specifications">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"></path></svg>
      </button>
    </div>
    <div class="specs-drawer__body">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          <div class="specs-drawer__category" {{ block.shopify_attributes }}>
            <h3 class="specs-drawer__category-title">{{ block.settings.title | escape }}</h3>
          </div>
        {%- elsif block.type == 'spec' -%}
          <div class="specs-drawer__row" {{ block.shopify_attributes }}>
            <span class="specs-drawer__label">{{ block.settings.label | escape }}</span>
            <span class="specs-drawer__value">{{ block.settings.value }}</span>
          </div>
        {%- elsif block.type == 'richtext' -%}
          <div class="specs-drawer__richtext rte" {{ block.shopify_attributes }}>
            {{ block.settings.content }}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- if section.settings.button_label != blank -%}
      <div class="specs-drawer__footer">
        <a href="{{ section.settings.button_url }}" class="specs-drawer__cta">{{ section.settings.button_label | escape }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .specs-drawer {
    position: fixed;
    inset: 0;
    z-index: 999;
    visibility: hidden;
    pointer-events: none;
  }
  .specs-drawer.is-open {
    visibility: visible;
    pointer-events: auto;
  }

  /* Overlay */
  .specs-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    transition: background 0.35s ease;
    cursor: pointer;
  }
  .specs-drawer.is-open .specs-drawer__overlay {
    background: rgba(0, 0, 0, 0.45);
  }

  /* Panel */
  .specs-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 480px;
    max-width: 90vw;
    background: #fff;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -4px 0 30px rgba(0, 0, 0, 0.1);
  }
  .specs-drawer.is-open .specs-drawer__panel {
    transform: translateX(0);
  }

  /* Header */
  .specs-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 28px;
    border-bottom: 1px solid #e8e8e8;
    flex-shrink: 0;
  }
  .specs-drawer__title {
    font-family: var(--heading-font-family, 'DM Serif Display', serif);
    font-size: 24px;
    font-weight: 700;
    color: #121212;
    margin: 0;
  }
  .specs-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 50%;
    color: #555;
    transition: background 0.2s, color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .specs-drawer__close:hover {
    background: #f0f0f0;
    color: #121212;
  }

  /* Body */
  .specs-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 0 28px 28px;
    -webkit-overflow-scrolling: touch;
  }

  /* Category heading */
  .specs-drawer__category {
    padding-top: 28px;
    padding-bottom: 12px;
    border-bottom: 2px solid #121212;
    margin-bottom: 4px;
  }
  .specs-drawer__category-title {
    font-family: var(--heading-font-family, 'DM Serif Display', serif);
    font-size: 18px;
    font-weight: 700;
    color: #121212;
    margin: 0;
    text-transform: none;
  }

  /* Spec rows */
  .specs-drawer__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 14px 0;
    border-bottom: 1px solid #f0f0f0;
    gap: 16px;
  }
  .specs-drawer__label {
    font-size: 14px;
    font-weight: 600;
    color: #555;
    flex-shrink: 0;
  }
  .specs-drawer__value {
    font-size: 14px;
    font-weight: 500;
    color: #121212;
    text-align: right;
  }

  /* Rich text block */
  .specs-drawer__richtext {
    padding: 16px 0;
    font-size: 14px;
    line-height: 1.6;
    color: #555;
  }

  /* Footer CTA */
  .specs-drawer__footer {
    padding: 20px 28px;
    border-top: 1px solid #e8e8e8;
    flex-shrink: 0;
  }
  .specs-drawer__cta {
    display: block;
    text-align: center;
    background: #2e72d2;
    color: #fff;
    padding: 16px;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s;
  }
  .specs-drawer__cta:hover {
    background: #2563b8;
  }

  @media (max-width: 480px) {
    .specs-drawer__panel {
      width: 100%;
      max-width: 100vw;
    }
    .specs-drawer__header {
      padding: 20px;
    }
    .specs-drawer__body {
      padding: 0 20px 20px;
    }
    .specs-drawer__footer {
      padding: 16px 20px;
    }
  }
</style>

<script>
  (function() {
    var section = document.getElementById('SpecsDrawer-{{ section.id }}');
    if (!section) return;
    var savedScrollY = 0;

    function openDrawer() {
      savedScrollY = window.scrollY;
      document.body.style.top = '-' + savedScrollY + 'px';
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
      section.classList.add('is-open');
    }

    function closeDrawer() {
      section.classList.remove('is-open');
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      window.scrollTo(0, savedScrollY);
    }

    section.querySelectorAll('[data-specs-drawer-close]').forEach(function(el) {
      el.addEventListener('click', closeDrawer);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && section.classList.contains('is-open')) {
        closeDrawer();
      }
    });

    document.addEventListener('click', function(e) {
      var trigger = e.target.closest('[data-open-specs-drawer="{{ section.id }}"]');
      if (!trigger) {
        trigger = e.target.closest('[data-open-specs-drawer]');
      }
      if (trigger) {
        e.preventDefault();
        openDrawer();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Specs drawer",
  "class": "section-specs-drawer",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Drawer title",
      "default": "Technical Specifications"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Footer button label",
