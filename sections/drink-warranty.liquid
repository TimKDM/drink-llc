<!-- Drink Satisfaction Guarantee Section -->
<!-- 2-column: satisfaction guarantee features + CTA left, visual placeholder right -->
<style>
.drink-warranty {
  padding: 120px 48px;
  background: #0D0D0D;
  font-family: var(--base-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  box-sizing: border-box;
}
.drink-warranty * { box-sizing: border-box; margin: 0; padding: 0; }
.drink-warranty-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  max-width: 1300px;
  margin: 0 auto;
}
.drink-warranty-eyebrow {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #777777;
  margin-bottom: 16px;
}
.drink-warranty-content h2 {
  font-family: var(--heading-font-family), serif;
  font-size: 52px;
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 24px;
  color: #F5F5F0;
}
.drink-warranty-content p {
  font-size: 18px;
  line-height: 1.7;
  color: #aaaaaa;
  margin-bottom: 32px;
}
.drink-warranty-features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 40px;
}
.drink-warranty-feat {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}
.drink-warranty-feat svg { width: 24px; height: 24px; color: #7CB518; flex-shrink: 0; margin-top: 2px; }
.drink-warranty-feat-text strong { display: block; font-size: 15px; margin-bottom: 2px; color: #F5F5F0; }
.drink-warranty-feat-text span { font-size: 14px; color: #999999; }
.drink-warranty-visual {
  aspect-ratio: 4/3;
  border-radius: 20px;
  overflow: hidden;
}
.drink-warranty-visual img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
/* Placeholder state — remove when you have a real photo */
.drink-warranty-visual-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 12px;
  background: linear-gradient(135deg, #1a1a1a, #222222);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 40px;
  text-align: center;
}
.drink-warranty-visual-placeholder svg { margin-bottom: 12px; }
.drink-warranty-visual-placeholder p {
  color: rgba(255,255,255,0.4);
  font-size: 14px;
  margin-top: 16px;
  font-weight: 600;
  margin-bottom: 0;
}
.drink-warranty .drink-btn-warranty {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #F5F5F0;
  color: #0D0D0D;
  padding: 18px 36px;
  border-radius: 8px;
  font-size: 17px;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.25s;
}
.drink-warranty .drink-btn-warranty:hover {
  background: #e0e0d8;
  transform: translateY(-2px);
}

/* Tablet */
@media (max-width: 1024px) {
  .drink-warranty-grid { grid-template-columns: 1fr; gap: 48px; }
  .drink-warranty-content h2 { font-size: 40px; }
}
/* Mobile */
@media (max-width: 768px) {
  .drink-warranty { padding: 64px 20px; }
  .drink-warranty-grid { gap: 40px; }
  .drink-warranty-content h2 { font-size: 32px; }
  .drink-warranty-content p { font-size: 16px; }
  .drink-warranty-features { grid-template-columns: 1fr; gap: 16px; }
  .drink-warranty-feat-text strong { font-size: 14px; }
  .drink-warranty-feat-text span { font-size: 13px; }
}
@media (max-width: 480px) {
  .drink-warranty-content h2 { font-size: 28px; }
}
</style>

<section class="drink-warranty">
  <div class="drink-warranty-grid">
    <div class="drink-warranty-content">
      <div class="drink-warranty-eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
      <div class="drink-warranty-features">
        {% for block in section.blocks %}
          {% if block.type == 'feature' %}
            <div class="drink-warranty-feat" {{ block.shopify_attributes }}>
              <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <div class="drink-warranty-feat-text">
                <strong>{{ block.settings.title }}</strong>
                <span>{{ block.settings.description }}</span>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      {% if section.settings.phone_number != blank %}
        <a href="tel:{{ section.settings.phone_number | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}" class="drink-btn-warranty">{{ section.settings.button_label }}</a>
      {% elsif section.settings.button_url != blank %}
        <a href="{{ section.settings.button_url }}" class="drink-btn-warranty">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
    <div class="drink-warranty-visual">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url: width: 1024 }}" alt="{{ section.settings.heading }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="lazy">
      {% else %}
        <div class="drink-warranty-visual-placeholder">
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"></path></svg>
          <p>Add an image in the theme editor</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Drink Satisfaction Guarantee",
  "class": "section-drink-warranty",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "The Promise"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not your thing? We'll make it right."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every tub ships with a simple guarantee. If you don't like it, we handle it. No forms. No runaround. Just reach out."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number (click-to-call)",
      "info": "Enter the phone number for the click-to-call link (e.g. 8667298075). Leave blank to use Button URL instead.",
      "default": ""
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL",
      "info": "Only used if Phone Number is blank."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Feature description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Drink Satisfaction Guarantee",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Full Refund",
            "description": "Don't like it? Money back. Simple."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "No Fillers",
            "description": "Clean formula. Nothing unnecessary."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Real Support",
            "description": "Humans. Not bots. Within one business day."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Free Shipping",
            "description": "Orders over $50 ship free."
          }
        }
      ]
    }
  ]
}
{% endschema %}
