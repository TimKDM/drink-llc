<!-- Euphree Accessories Section — Shopify Custom Liquid with Theme Customizer editability -->
<!-- 4-card accessory grid + highlight callout section -->
<style>
.euphree-accessories {
  padding: 120px 48px;
  background: #ffffff;
  font-family: var(--base-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}
.euphree-accessories-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0;
}
.euphree-accessories-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.euphree-accessories-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
}
.euphree-accessories > *:not(.euphree-accessories-bg):not(.euphree-accessories-overlay) {
  position: relative;
  z-index: 2;
}
.euphree-accessories * { box-sizing: border-box; margin: 0; padding: 0; }
.euphree-acc-header {
  text-align: center;
  margin-bottom: 32px;
}
.euphree-acc-eyebrow {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #888888;
  margin-bottom: 16px;
}
.euphree-acc-header h2 {
  font-family: var(--heading-font-family), serif;
  font-size: 56px;
  font-weight: 700;
  color: #121212;
  line-height: 1.1;
}
.euphree-acc-intro {
  max-width: 700px;
  margin: 0 auto 64px;
  text-align: center;
  font-size: 18px;
  line-height: 1.7;
  color: #555555;
}
.euphree-acc-intro strong { color: #121212; }
.euphree-acc-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  max-width: 1300px;
  margin: 0 auto 48px;
}
.euphree-acc-card {
  border-radius: 16px;
  overflow: hidden;
  background: #ffffff;
  cursor: pointer;
  transition: transform 0.3s;
  display: flex;
  flex-direction: column;
}
.euphree-acc-card:hover { transform: translateY(-4px); }
.euphree-acc-card a.euphree-acc-card-link {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
  text-decoration: none;
  color: inherit;
}
.euphree-acc-card-img {
  width: 100%;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #f5f5f3 0%, #eeeee8 100%);
}
.euphree-acc-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.euphree-acc-card-label {
  padding: 16px 20px;
  background: #ffffff;
  color: #121212;
}
.euphree-acc-card-label h4 { font-size: 18px; font-weight: 700; margin-bottom: 2px; color: #121212; }
.euphree-acc-card-label p { font-size: 14px; color: #555555; }
.euphree-acc-highlight {
  max-width: 1300px;
  margin: 0 auto;
  background: #f5f5f3;
  border-radius: 20px;
  padding: 64px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
}
.euphree-acc-highlight-visual {
  border-radius: 12px;
  overflow: hidden;
}
.euphree-acc-highlight-visual img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 12px;
}
.euphree-acc-highlight h3 {
  font-family: var(--heading-font-family), serif;
  font-size: 36px;
  font-weight: 700;
  margin-bottom: 16px;
  line-height: 1.2;
  color: #121212;
}
.euphree-acc-highlight p {
  font-size: 17px;
  line-height: 1.7;
  color: #555555;
  margin-bottom: 24px;
}
.euphree-acc-highlight .euphree-btn-acc {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: #2e72d2;
  color: #ffffff;
  padding: 16px 32px;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 700;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: all 0.25s;
}
.euphree-acc-highlight .euphree-btn-acc:hover {
  background: #2563b8;
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(46,114,210,0.3);
}

/* Tablet */
@media (max-width: 1024px) {
  .euphree-acc-grid { grid-template-columns: repeat(2, 1fr); }
  .euphree-acc-highlight { grid-template-columns: 1fr; padding: 40px; }
  .euphree-acc-header h2 { font-size: 40px; }
}
/* Mobile */
@media (max-width: 768px) {
  .euphree-accessories { padding: 64px 20px; }
  .euphree-acc-header h2 { font-size: 32px; }
  .euphree-acc-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
  .euphree-acc-intro { font-size: 15px; margin-bottom: 40px; padding: 0; }
  .euphree-acc-highlight { padding: 24px; gap: 24px; border-radius: 16px; }
  .euphree-acc-highlight h3 { font-size: 26px; }
  .euphree-acc-highlight p { font-size: 15px; }
  .euphree-acc-card-label h4 { font-size: 15px; }
  .euphree-acc-card-label p { font-size: 12px; }
  .euphree-acc-card-label { padding: 14px; }
}
@media (max-width: 480px) {
  .euphree-acc-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
  .euphree-acc-highlight h3 { font-size: 22px; }
  .euphree-acc-header h2 { font-size: 28px; }
}
</style>

<section class="euphree-accessories">
  {% if section.settings.bg_image != blank %}
    <div class="euphree-accessories-bg">
      <img src="{{ section.settings.bg_image | image_url: width: 1920 }}" alt="" width="{{ section.settings.bg_image.width }}" height="{{ section.settings.bg_image.height }}" loading="lazy">
    </div>
    <div class="euphree-accessories-overlay" style="background: {{ section.settings.overlay_color }}"></div>
  {% endif %}
  <div class="euphree-acc-header">
    <div class="euphree-acc-eyebrow">{{ section.settings.eyebrow }}</div>
    <h2>{{ section.settings.heading }}</h2>
  </div>
  <div class="euphree-acc-intro">
    {{ section.settings.intro_text }}
  </div>

  <div class="euphree-acc-grid">
    {% for block in section.blocks %}
      <div class="euphree-acc-card" {{ block.shopify_attributes }}>
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}" class="euphree-acc-card-link">
        {% endif %}
          <div class="euphree-acc-card-img">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.name }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="lazy">
            {% endif %}
          </div>
          <div class="euphree-acc-card-label">
            <h4>{{ block.settings.name }}</h4>
            <p>{{ block.settings.description }}</p>
          </div>
        {% if block.settings.link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <!-- Highlight callout -->
  <div class="euphree-acc-highlight">
    <div class="euphree-acc-highlight-visual">
      {% if section.settings.highlight_image != blank %}
        <img src="{{ section.settings.highlight_image | image_url: width: 800 }}" alt="{{ section.settings.highlight_heading }}" width="{{ section.settings.highlight_image.width }}" height="{{ section.settings.highlight_image.height }}" loading="lazy">
      {% endif %}
    </div>
    <div>
      <h3>{{ section.settings.highlight_heading }}</h3>
      <p>{{ section.settings.highlight_description }}</p>
      {% if section.settings.highlight_button_label != blank %}
        <a href="{{ section.settings.highlight_button_url }}" class="euphree-btn-acc">{{ section.settings.highlight_button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Euphree Accessories",
  "class": "section-euphree-accessories",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Designed to Fit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Good Accessories Are the Key to Getting the Most Out of Your Bike"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro Text",
      "default": "<p>Without accessories, it's just a bike and a backpack — and a sweaty back. A lot of brands don't have their own accessories, or they have cheap ones that don't fit the bike. <strong>Euphree designed a full line of bags, baskets, locks, and panniers that fit our bikes perfectly.</strong> No mix and match. No compromise.</p>"
    },
    {
      "type": "image_picker",
      "id": "highlight_image",
      "label": "Highlight Image"
    },
    {
      "type": "text",
      "id": "highlight_heading",
      "label": "Highlight Heading",
      "default": "Designed Specifically for Euphree Bikes"
    },
    {
      "type": "textarea",
      "id": "highlight_description",
      "label": "Highlight Description",
      "default": "Most brands don't have their own accessories — or they have cheap ones that don't fit well. Euphree designed every bag, basket, and lock to integrate perfectly with your bike. Customers consistently tell us they'd choose a well-accessorized bike over a higher-spec bare one."
    },
    {
      "type": "text",
      "id": "highlight_button_label",
      "label": "Highlight Button Label",
      "default": "Shop All Accessories →"
    },
    {
      "type": "url",
      "id": "highlight_button_url",
      "label": "Highlight Button URL"
    },
    {
      "type": "header",
      "content": "Section Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color_background",
      "id": "overlay_color",
      "label": "Overlay Color",
      "info": "Semi-transparent overlay on top of the background image.",
      "default": "rgba(255,255,255,0.9)"
    }
  ],
  "blocks": [
    {
      "type": "accessory",
      "name": "Accessory",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Accessory Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Accessory Name",
          "default": "Accessory"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Accessory description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Euphree Accessories",
      "settings": {
