{%- comment -%} Drink LLC — Featured Collection Section {%- endcomment -%}

<section class="section featured-collection">
  <div class="container">
    <div class="featured-collection__header">
      <h2>{{ section.settings.heading | default: 'Pick Your Flavor' }}</h2>
      {%- if section.settings.collection != blank -%}
        <a href="{{ section.settings.collection.url }}" class="label featured-collection__link">View All</a>
      {%- endif -%}
    </div>

    {%- if section.settings.collection != blank -%}
      <div class="grid grid--3">
        {%- for product in section.settings.collection.products limit: section.settings.product_count -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="featured-collection__empty">Select a collection to display here.</p>
    {%- endif -%}
  </div>
</section>

<style>
  .featured-collection__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-xl);
  }

  .featured-collection__link {
    color: var(--color-ash);
    transition: color var(--transition-fast);
  }

  .featured-collection__link:hover {
    color: var(--color-offwhite);
    opacity: 1;
  }

  .featured-collection__empty {
    color: var(--color-ash);
    text-align: center;
    padding: var(--space-xl) 0;
  }
</style>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pick Your Flavor"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Products to show",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
