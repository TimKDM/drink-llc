{%- comment -%}
  Sizing Drawer — Slide-in panel from right side
  Triggered by a button with [data-open-sizing-drawer], displays sizing info
{%- endcomment -%}

<div id="SizingDrawer-{{ section.id }}" class="sizing-drawer" data-sizing-drawer>
  <div class="sizing-drawer__overlay" data-sizing-drawer-close></div>
  <div class="sizing-drawer__panel">
    <div class="sizing-drawer__header">
      <h2 class="sizing-drawer__title">{{ section.settings.title | default: 'Sizing Guide' }}</h2>
      <button class="sizing-drawer__close" data-sizing-drawer-close aria-label="Close sizing guide">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"></path></svg>
      </button>
    </div>
    <div class="sizing-drawer__body">
      {%- for block in section.blocks -%}
        {%- if block.type == 'heading' -%}
          <div class="sizing-drawer__category" {{ block.shopify_attributes }}>
            <h3 class="sizing-drawer__category-title">{{ block.settings.title | escape }}</h3>
          </div>
        {%- elsif block.type == 'measurement' -%}
          <div class="sizing-drawer__row" {{ block.shopify_attributes }}>
            <span class="sizing-drawer__label">{{ block.settings.label | escape }}</span>
            <span class="sizing-drawer__value">{{ block.settings.value }}</span>
          </div>
        {%- elsif block.type == 'image' -%}
          <div class="sizing-drawer__image" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'sizing-drawer__img' }}
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <p class="sizing-drawer__caption">{{ block.settings.caption | escape }}</p>
            {%- endif -%}
          </div>
        {%- elsif block.type == 'richtext' -%}
          <div class="sizing-drawer__richtext rte" {{ block.shopify_attributes }}>
            {{ block.settings.content }}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- if section.settings.button_label != blank -%}
      <div class="sizing-drawer__footer">
        <a href="{{ section.settings.button_url }}" class="sizing-drawer__cta">{{ section.settings.button_label | escape }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .sizing-drawer {
    position: fixed;
    inset: 0;
    z-index: 999;
    visibility: hidden;
    pointer-events: none;
  }
  .sizing-drawer.is-open {
    visibility: visible;
    pointer-events: auto;
  }

  .sizing-drawer__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    transition: background 0.35s ease;
    cursor: pointer;
  }
  .sizing-drawer.is-open .sizing-drawer__overlay {
    background: rgba(0, 0, 0, 0.45);
  }

  .sizing-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 480px;
    max-width: 90vw;
    background: #fff;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -4px 0 30px rgba(0, 0, 0, 0.1);
  }
  .sizing-drawer.is-open .sizing-drawer__panel {
    transform: translateX(0);
  }

  .sizing-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 28px;
    border-bottom: 1px solid #e8e8e8;
    flex-shrink: 0;
  }
  .sizing-drawer__title {
    font-family: var(--heading-font-family, 'DM Serif Display', serif);
    font-size: 24px;
    font-weight: 700;
    color: #121212;
    margin: 0;
  }
  .sizing-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 50%;
    color: #555;
    transition: background 0.2s, color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sizing-drawer__close:hover {
    background: #f0f0f0;
    color: #121212;
  }

  .sizing-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 0 28px 28px;
    -webkit-overflow-scrolling: touch;
  }

  .sizing-drawer__category {
    padding-top: 28px;
    padding-bottom: 12px;
    border-bottom: 2px solid #121212;
    margin-bottom: 4px;
  }
  .sizing-drawer__category-title {
    font-family: var(--heading-font-family, 'DM Serif Display', serif);
    font-size: 18px;
    font-weight: 700;
    color: #121212;
    margin: 0;
    text-transform: none;
  }

  .sizing-drawer__row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 14px 0;
    border-bottom: 1px solid #f0f0f0;
    gap: 16px;
  }
  .sizing-drawer__label {
    font-size: 14px;
    font-weight: 600;
    color: #555;
    flex-shrink: 0;
  }
  .sizing-drawer__value {
    font-size: 14px;
    font-weight: 500;
    color: #121212;
    text-align: right;
  }

  .sizing-drawer__image {
    padding: 20px 0;
    text-align: center;
  }
  .sizing-drawer__img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }
  .sizing-drawer__caption {
    font-size: 13px;
    color: #888;
    margin-top: 8px;
  }

  .sizing-drawer__richtext {
    padding: 16px 0;
    font-size: 14px;
    line-height: 1.6;
    color: #555;
  }

  .sizing-drawer__footer {
    padding: 20px 28px;
    border-top: 1px solid #e8e8e8;
    flex-shrink: 0;
  }
  .sizing-drawer__cta {
    display: block;
    text-align: center;
    background: #2e72d2;
    color: #fff;
    padding: 16px;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s;
  }
  .sizing-drawer__cta:hover {
    background: #2563b8;
  }

  @media (max-width: 480px) {
    .sizing-drawer__panel {
      width: 100%;
      max-width: 100vw;
    }
    .sizing-drawer__header {
      padding: 20px;
    }
    .sizing-drawer__body {
      padding: 0 20px 20px;
    }
    .sizing-drawer__footer {
      padding: 16px 20px;
    }
  }
</style>

<script>
  (function() {
    var section = document.getElementById('SizingDrawer-{{ section.id }}');
    if (!section) return;
    var savedScrollY = 0;

    function openDrawer() {
      savedScrollY = window.scrollY;
      document.body.style.top = '-' + savedScrollY + 'px';
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
      section.classList.add('is-open');
    }

    function closeDrawer() {
      section.classList.remove('is-open');
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      window.scrollTo(0, savedScrollY);
    }

    section.querySelectorAll('[data-sizing-drawer-close]').forEach(function(el) {
      el.addEventListener('click', closeDrawer);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && section.classList.contains('is-open')) {
        closeDrawer();
      }
    });

    document.addEventListener('click', function(e) {
      var trigger = e.target.closest('[data-open-sizing-drawer="{{ section.id }}"]');
      if (!trigger) {
        trigger = e.target.closest('[data-open-sizing-drawer]');
      }
      if (trigger) {
        e.preventDefault();
        openDrawer();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Sizing drawer",
  "class": "section-sizing-drawer",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Drawer title",
      "default": "Sizing Guide"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Footer button label",
      "info": "Leave blank to hide"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Footer button link"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Section heading",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Fit Details"
        }
      ]
    },
    {
      "type": "measurement",
      "name": "Measurement row",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Rider Height"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "5'2\" – 6'0\""
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Sizing diagram"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    },
    {
      "type": "richtext",
      "name": "Rich text",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sizing drawer",
      "blocks": [
        { "type": "heading", "settings": { "title": "Fit Details" } },
        { "type": "measurement", "settings": { "label": "Rider Height", "value": "5'2\" – 6'0\"" } },
        { "type": "measurement", "settings": { "label": "Standover Height", "value": "Check product specs" } },
        { "type": "measurement", "settings": { "label": "Seat Height Range", "value": "Check product specs" } },
        { "type": "measurement", "settings": { "label": "Max Payload", "value": "350 lbs" } }
      ]
    }
  ]
}
{% endschema %}
