{%- style -%}
  .divine-story-page {
    {% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
    {% if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' %}
      color: {{ section.settings.text_color }};
    {% endif %}
  }
  {% if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' %}
    .divine-story-page h1,
    .divine-story-page h2,
    .divine-story-page h3 {
      color: {{ section.settings.text_color }};
    }
  {% endif %}
  {% if section.settings.accent_color != blank and section.settings.accent_color != 'rgba(0,0,0,0)' %}
    .divine-story-page .divine-section-label,
    .divine-story-page .divine-story__values-icon svg {
      color: {{ section.settings.accent_color }};
      stroke: {{ section.settings.accent_color }};
    }
  {% endif %}
{%- endstyle -%}

<div class="divine-story-page">
  {%- for block in section.blocks -%}
    {%- case block.type -%}

      {%- when 'hero' -%}
        <div class="divine-story__hero" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="divine-story__hero-image">
              {{
                block.settings.image
                | image_url: width: 1600
                | image_tag:
                  loading: 'eager',
                  widths: '375, 750, 1100, 1600',
                  sizes: '100vw'
              }}
              <div class="divine-story__hero-overlay"></div>
              <div class="divine-story__hero-content">
                {%- if block.settings.caption != blank -%}
                  <span class="divine-section-label">{{ block.settings.caption }}</span>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <h1>{{ block.settings.heading }}</h1>
                {%- endif -%}
              </div>
            </div>
          {%- else -%}
            <div class="divine-story__hero-simple">
              {%- if block.settings.caption != blank -%}
                <span class="divine-section-label">{{ block.settings.caption }}</span>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h1>{{ block.settings.heading }}</h1>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

      {%- when 'intro' -%}
        <div class="divine-story__intro" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h2>{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="divine-story__intro-text">{{ block.settings.text }}</div>
          {%- endif -%}
        </div>

      {%- when 'image_text' -%}
        <div class="divine-story__section {% if block.settings.layout == 'image_right' %}divine-story__section--reversed{% endif %} {% if block.settings.use_alt_bg %}divine-section-alt{% endif %}" {{ block.shopify_attributes }}>
          <div class="divine-story__section-grid">
            <div class="divine-story__section-image">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    widths: '375, 550, 800',
                    sizes: '(min-width: 768px) 50vw, 100vw'
                }}
              {%- else -%}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="divine-story__section-content">
              {%- if block.settings.caption != blank -%}
                <span class="divine-section-label">{{ block.settings.caption }}</span>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h2>{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="divine-story__section-text">{{ block.settings.text }}</div>
              {%- endif -%}
              {%- if block.settings.button_label != blank -%}
                <a href="{{ block.settings.button_link }}" class="divine-btn divine-btn-primary">{{ block.settings.button_label }}</a>
              {%- endif -%}
            </div>
          </div>
        </div>

      {%- when 'values' -%}
        <div class="divine-story__values {% if block.settings.use_alt_bg %}divine-section-alt{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <div class="divine-section-header">
              {%- if block.settings.caption != blank -%}
                <span class="divine-section-label">{{ block.settings.caption }}</span>
              {%- endif -%}
              <h2 class="divine-section-title">{{ block.settings.heading }}</h2>
            </div>
          {%- endif -%}
          <div class="divine-story__values-grid">
            {%- if block.settings.value_1_title != blank -%}
              <div class="divine-story__values-item">
                <div class="divine-story__values-icon">
                  <svg viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </div>
                <h3>{{ block.settings.value_1_title }}</h3>
                {%- if block.settings.value_1_text != blank -%}
                  <p>{{ block.settings.value_1_text }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if block.settings.value_2_title != blank -%}
              <div class="divine-story__values-item">
                <div class="divine-story__values-icon">
                  <svg viewBox="0 0 24 24"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h3>{{ block.settings.value_2_title }}</h3>
                {%- if block.settings.value_2_text != blank -%}
                  <p>{{ block.settings.value_2_text }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if block.settings.value_3_title != blank -%}
              <div class="divine-story__values-item">
                <div class="divine-story__values-icon">
                  <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                </div>
                <h3>{{ block.settings.value_3_title }}</h3>
                {%- if block.settings.value_3_text != blank -%}
                  <p>{{ block.settings.value_3_text }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if block.settings.value_4_title != blank -%}
              <div class="divine-story__values-item">
                <div class="divine-story__values-icon">
                  <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                </div>
                <h3>{{ block.settings.value_4_title }}</h3>
                {%- if block.settings.value_4_text != blank -%}
                  <p>{{ block.settings.value_4_text }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>

      {%- when 'cta' -%}
        <div class="divine-story__cta {% if block.settings.use_dark_bg %}divine-story__cta--dark{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h2>{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p>{{ block.settings.text }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link }}" class="divine-btn divine-btn-primary">{{ block.settings.button_label }}</a>
          {%- endif -%}
        </div>

    {%- endcase -%}
  {%- endfor -%}
</div>

<style>
  /* Story Page Hero */
  .divine-story__hero-image {
    position: relative;
    width: 100%;
    max-height: 50vh;
    overflow: hidden;
  }
  .divine-story__hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .divine-story__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);
  }
  .divine-story__hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px 20px;
    color: #fff;
    text-align: center;
  }
  .divine-story__hero-content h1 {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 400;
    margin: 0;
    color: #fff;
  }
  .divine-story__hero-content .divine-section-label {
    color: var(--color-accent-hex);
    margin-bottom: 8px;
  }
  .divine-story__hero-simple {
    text-align: center;
    padding: 48px 20px;
  }
  .divine-story__hero-simple h1 {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 400;
    margin: 0;
  }

  /* Intro Section */
  .divine-story__intro {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 20px;
    text-align: center;
  }
  .divine-story__intro h2 {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 400;
    margin-bottom: 16px;
    margin-top: 0;
    line-height: 1.3;
  }
  .divine-story__intro-text {
    font-size: 15px;
    color: var(--color-text-muted);
    line-height: 1.8;
  }
  .divine-story__intro-text p {
    margin-bottom: 16px;
  }

  /* Image + Text Sections */
  .divine-story__section {
    padding: 40px 20px;
  }
  .divine-story__section-image {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 24px;
  }
  .divine-story__section-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .divine-story__section-content h2 {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 400;
    margin-bottom: 16px;
    margin-top: 0;
    line-height: 1.3;
  }
  .divine-story__section-text {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 20px;
  }
  .divine-story__section-text p {
    margin-bottom: 12px;
  }

  /* Values Grid */
  .divine-story__values {
    padding: 40px 20px;
  }
  .divine-story__values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 24px;
  }
  .divine-story__values-item {
    text-align: center;
  }
  .divine-story__values-icon {
    margin-bottom: 12px;
  }
  .divine-story__values-icon svg {
    width: 32px;
    height: 32px;
    stroke: var(--color-accent-dark);
    stroke-width: 1.5;
    fill: none;
  }
  .divine-story__values-item h3 {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 6px;
    margin-top: 0;
  }
  .divine-story__values-item p {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* CTA Section */
  .divine-story__cta {
    text-align: center;
    padding: 48px 20px;
  }
  .divine-story__cta--dark {
    background: var(--color-foreground-hex);
    color: var(--color-background-hex);
  }
  .divine-story__cta--dark h2 {
    color: var(--color-background-hex);
  }
  .divine-story__cta--dark p {
    color: rgba(255,255,255,0.7);
  }
  .divine-story__cta h2 {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 400;
    margin-bottom: 12px;
    margin-top: 0;
  }
  .divine-story__cta p {
    font-size: 14px;
    color: var(--color-text-muted);
    margin-bottom: 20px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
  .divine-story__cta .divine-btn {
    display: inline-flex;
    width: auto;
  }

  @media screen and (min-width: 768px) {
    .divine-story__hero-content {
      padding: 48px 40px;
    }
    .divine-story__hero-content h1 {
      font-size: 40px;
    }
    .divine-story__hero-simple h1 {
      font-size: 40px;
    }
    .divine-story__hero-image {
      max-height: 60vh;
    }
    .divine-story__intro {
      padding: 60px 40px;
    }
    .divine-story__intro h2 {
      font-size: 28px;
    }
    .divine-story__section {
      padding: 60px 40px;
    }
    .divine-story__section-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }
    .divine-story__section--reversed .divine-story__section-grid {
      direction: rtl;
    }
    .divine-story__section--reversed .divine-story__section-grid > * {
      direction: ltr;
    }
    .divine-story__section-image {
      margin-bottom: 0;
      aspect-ratio: 1;
    }
    .divine-story__section-content h2 {
      font-size: 26px;
    }
    .divine-story__values {
      padding: 60px 40px;
    }
    .divine-story__values-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
    }
    .divine-story__values-icon svg {
      width: 40px;
      height: 40px;
    }
    .divine-story__cta {
      padding: 64px 40px;
    }
    .divine-story__cta h2 {
      font-size: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "Divine Story Page",
  "tag": "section",
  "class": "divine-story-page-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color"
    }
  ],
  "blocks": [
    {
      "type": "hero",
      "name": "Page Hero",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Our Story"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "How We Got Here (And Why We're Not Stopping)"
        }
      ]
    },
    {
      "type": "intro",
      "name": "Introduction",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "type": "image_text",
      "name": "Image + Text",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Layout",
          "options": [
            { "value": "image_left", "label": "Image left" },
            { "value": "image_right", "label": "Image right" }
          ],
          "default": "image_left"
        },
        {
          "type": "checkbox",
          "id": "use_alt_bg",
          "label": "Use alternate background",
          "default": false
        }
      ]
    },
    {
      "type": "values",
      "name": "Values Grid",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "The Things We Won't Bend On"
        },
        {
          "type": "text",
          "id": "value_1_title",
          "label": "Value 1 title",
          "default": "Quality Over Everything"
        },
        {
          "type": "text",
          "id": "value_1_text",
          "label": "Value 1 text",
          "default": "We'd rather carry fewer products than compromise on a single one. Every ingredient is selected with intention and tested with rigor."
        },
        {
          "type": "text",
          "id": "value_2_title",
          "label": "Value 2 title",
          "default": "Radical Transparency"
        },
        {
          "type": "text",
          "id": "value_2_text",
          "label": "Value 2 text",
          "default": "You deserve the full picture — where it's from, how it's tested, what's in it. We don't do hidden fillers or vague labels."
        },
        {
          "type": "text",
          "id": "value_3_title",
          "label": "Value 3 title",
          "default": "People and Planet"
        },
        {
          "type": "text",
          "id": "value_3_text",
          "label": "Value 3 text",
          "default": "We partner with growers who care about sustainable practices and fair wages. Good ingredients start with good relationships."
        },
        {
          "type": "text",
          "id": "value_4_title",
          "label": "Value 4 title",
          "default": "Your Success Is the Point"
        },
        {
          "type": "text",
          "id": "value_4_text",
          "label": "Value 4 text",
          "default": "We built this for creators, makers, and kitchen innovators. Your success is the whole point — and we're here to support every step."
        },
        {
          "type": "checkbox",
          "id": "use_alt_bg",
          "label": "Use alternate background",
          "default": true
        }
      ]
    },
    {
      "type": "cta",
      "name": "Call to Action",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Ready to Make Something Great?"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Join the community of creators, chefs, and wellness brands who trust Divine for the ingredients that matter most."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Explore Collections"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "use_dark_bg",
          "label": "Use dark background",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Story Page",
      "blocks": [
        {
          "type": "hero",
          "settings": {
            "caption": "Our Story",
            "heading": "How We Got Here (And Why We're Not Stopping)"
          }
        },
        {
          "type": "intro",
          "settings": {
            "heading": "We Believe Good Food Should Be Simple, Honest, and Backed by Facts",
            "text": "<p>Divine Ingredients exists because we think you deserve to know exactly what's in your food — and where it came from. We're not here to slap a label on something and call it organic. We go to the farms. We test the batches. We build relationships that last.</p><p>Whether you're creating in your kitchen, developing products, or growing your brand, we're in your corner. Not as a supplier — as your people.</p>"
          }
        },
        {
          "type": "image_text",
          "settings": {
            "caption": "How It Started",
            "heading": "We Couldn't Find What We Wanted, So We Built It",
            "text": "<p>It started with frustration. We wanted clean, organic ingredients we could actually trace back to the source — and they didn't exist in the way we needed them to. So we bought plane tickets, visited farms, and started building the kind of supply chain we wished someone else had already built.</p><p>From matcha fields in Japan to spice growers in India and tea estates in Sri Lanka, every partnership is rooted in trust, fair trade, and a shared love for doing things right.</p>",
            "layout": "image_left"
          }
        },
        {
          "type": "image_text",
          "settings": {
            "caption": "Our Process",
            "heading": "We Test Everything Because Facts Actually Matter",
            "text": "<p>Every ingredient that carries our name has been lab-tested by independent third parties. Not some of them — all of them. Purity, potency, heavy metals, allergens. If it doesn't pass, it doesn't ship.</p><p>Zero synthetic additives. Zero fillers. Zero artificial anything. We know that sounds like every brand's tagline, but for us it's the baseline. The bare minimum. The starting point.</p>",
            "layout": "image_right",
            "use_alt_bg": true
          }
        },
        {
          "type": "values",
          "settings": {
            "caption": "Our Commitments",
            "heading": "The Things We Won't Bend On",
            "value_1_title": "Quality Over Everything",
            "value_1_text": "We'd rather carry fewer products than compromise on a single one. Every ingredient is selected with intention and tested with rigor.",
            "value_2_title": "Radical Transparency",
            "value_2_text": "You deserve the full picture — where it's from, how it's tested, what's in it. We don't do hidden fillers or vague labels.",
            "value_3_title": "People and Planet",
            "value_3_text": "We partner with growers who care about sustainable practices and fair wages. Good ingredients start with good relationships.",
            "value_4_title": "Your Success Is the Point",
            "value_4_text": "We built this for creators, makers, and kitchen innovators. Your success is the whole point — and we're here to support every step.",
            "use_alt_bg": false
          }
        },
        {
          "type": "image_text",
          "settings": {
            "caption": "Our Community",
            "heading": "You're in Good Company",
            "text": "<p>When you choose Divine, you're joining a community of people who genuinely care about what goes into their food, their products, and their bodies. That's not a niche — that's a movement.</p><p>From home chefs discovering the joy of real matcha to wellness brands formulating their next big thing, café owners pouring signature drinks, and creators pushing the boundaries of what good food can be — we're honored to be part of your story.</p>",
            "button_label": "Shop All Collections",
