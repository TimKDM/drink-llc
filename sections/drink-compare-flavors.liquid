<!-- Drink Compare Flavors Section — Shopify Online Store 2.0 -->
<!-- Interactive toggle comparison table with dynamic flavor blocks -->
<!-- NOTE: This section includes JavaScript for the flavor toggle functionality -->
<style>
.drink-compare {
  padding: 100px 48px;
  background: #141414;
  text-align: center;
  font-family: var(--base-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  box-sizing: border-box;
}
.drink-compare * { box-sizing: border-box; margin: 0; padding: 0; }
.drink-compare-eyebrow {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #777777;
  margin-bottom: 16px;
}
.drink-compare h2 {
  font-family: var(--heading-font-family), serif;
  font-size: 52px;
  font-weight: 700;
  margin-bottom: 16px;
  color: #F5F5F0;
}
.drink-compare > p {
  font-size: 18px;
  color: #aaaaaa;
  margin-bottom: 48px;
}

/* Model selector toggles */
.drink-compare-selector {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-bottom: 48px;
  flex-wrap: wrap;
}
.drink-compare-toggle {
  display: flex;
  align-items: center;
  gap: 12px;
  background: #1a1a1a;
  border: 2px solid transparent;
  border-radius: 12px;
  padding: 16px 24px;
  cursor: pointer;
  transition: all 0.25s;
  user-select: none;
}
.drink-compare-toggle:hover { border-color: #444444; }
.drink-compare-toggle.active { border-color: #FFE566; box-shadow: 0 4px 20px rgba(255,229,102,0.1); }
.drink-toggle-check {
  width: 24px;
  height: 24px;
  border-radius: 6px;
  border: 2px solid #555555;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  flex-shrink: 0;
}
.drink-compare-toggle.active .drink-toggle-check {
  background: #FFE566;
  border-color: #FFE566;
}
.drink-toggle-check svg { opacity: 0; transition: opacity 0.15s; stroke: #0D0D0D; }
.drink-compare-toggle.active .drink-toggle-check svg { opacity: 1; }
.drink-toggle-info { text-align: left; }
.drink-toggle-name {
  font-family: var(--heading-font-family), serif;
  font-size: 18px;
  font-weight: 700;
  color: #F5F5F0;
}
.drink-toggle-tagline {
  font-size: 13px;
  color: #999999;
  margin-top: 2px;
}
.drink-compare-hint {
  font-size: 14px;
  color: #777777;
  margin-bottom: 32px;
}

/* Comparison table */
.drink-compare-table-wrap {
  max-width: 1400px;
  margin: 0 auto;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.drink-compare-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  text-align: left;
}
.drink-compare-table thead th {
  position: sticky;
  top: 72px;
  background: #141414;
  z-index: 5;
  padding: 0 16px 20px;
  vertical-align: bottom;
}
.drink-compare-table th.drink-col-label { width: 180px; min-width: 160px; }
.drink-compare-col-head {
  background: #1a1a1a;
  border-radius: 16px 16px 0 0;
  padding: 28px 16px 20px;
  text-align: center;
  min-width: 200px;
}
.drink-compare-product-photo {
  width: 100%;
  max-width: 200px;
  height: auto;
  margin: 0 auto 12px;
  display: block;
  filter: drop-shadow(0 4px 12px rgba(0,0,0,0.1));
}
.drink-compare-col-head h4 {
  font-family: var(--heading-font-family), serif;
  font-size: 22px;
  font-weight: 700;
  color: #F5F5F0;
  margin-bottom: 4px;
}
.drink-col-price {
  font-size: 15px;
  color: #aaaaaa;
  font-weight: 600;
}
.drink-col-price .drink-price-was {
  text-decoration: line-through;
  color: #c0c0c0;
  font-weight: 400;
  margin-left: 6px;
}
.drink-col-price .drink-price-now { color: #c0392b; font-weight: 800; }
.drink-col-rating {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-top: 8px;
  font-size: 13px;
  color: #aaaaaa;
}
.drink-col-rating .drink-stars-sm { color: #b8963e; font-size: 15px; letter-spacing: 1px; }

/* Table body */
.drink-compare-table tbody tr { transition: background 0.15s; }
.drink-compare-table tbody tr:hover { background: rgba(255,255,255,0.03); }
.drink-compare-table td, .drink-compare-table th {
  padding: 16px;
  font-size: 15px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  vertical-align: middle;
}
.drink-compare-table .drink-row-label {
  font-weight: 700;
  color: #cccccc;
  font-size: 14px;
  letter-spacing: 0.3px;
  white-space: nowrap;
}
.drink-compare-table .drink-row-label svg { width: 16px; height: 16px; opacity: 0.4; margin-right: 8px; vertical-align: -2px; }
.drink-compare-table td {
  text-align: center;
  color: #aaaaaa;
  font-weight: 500;
  min-width: 200px;
}
.drink-compare-table td strong { color: #F5F5F0; font-weight: 700; }

/* Category header rows */
.drink-compare-table .drink-cat-row td, .drink-compare-table .drink-cat-row th {
  padding-top: 28px;
  border-bottom: 2px solid rgba(255,255,255,0.1);
}
.drink-compare-table .drink-cat-row .drink-row-label {
  font-family: var(--heading-font-family), serif;
  font-size: 18px;
  font-weight: 700;
  color: #F5F5F0;
  letter-spacing: 0;
}

/* CTA row */
.drink-compare-table .drink-cta-row td {
  padding: 24px 16px 32px;
  border-bottom: none;
  text-align: center;
}
.drink-btn-compare {
  display: inline-block;
  background: #F5F5F0;
  color: #0D0D0D;
  padding: 14px 16px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.2s;
  text-align: center;
  white-space: nowrap;
}
.drink-btn-compare:hover {
  background: #e0e0d8;
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.15);
}

/* Column visibility */
.drink-compare-table .drink-col-hidden { display: none; }

/* Featured column header accent */
.drink-compare-col-head.drink-featured-head {
  background: linear-gradient(180deg, #1a1a1a 0%, #222222 100%);
}

/* Mobile scroll hint */
.drink-compare-scroll-hint {
  display: none;
  text-align: center;
  font-size: 13px;
  color: #777777;
  margin-top: 12px;
}
@media (max-width: 900px) {
  .drink-compare-scroll-hint { display: block; }
  .drink-compare-selector { gap: 10px; }
  .drink-compare-toggle { padding: 12px 16px; }
  .drink-toggle-name { font-size: 16px; }
}

/* Tablet */
@media (max-width: 1024px) {
  .drink-compare h2 { font-size: 40px; }
}
/* Mobile */
@media (max-width: 768px) {
  .drink-compare { padding: 64px 20px; }
  .drink-compare h2 { font-size: 32px; }
  .drink-compare > p { font-size: 15px; margin-bottom: 32px; }
  .drink-compare-selector { gap: 8px; flex-direction: column; align-items: center; }
  .drink-compare-toggle { padding: 12px 16px; width: 100%; max-width: 320px; }
  .drink-toggle-name { font-size: 15px; }
  .drink-toggle-tagline { font-size: 12px; }
  .drink-compare-hint { font-size: 13px; margin-bottom: 20px; }
  .drink-compare-table td, .drink-compare-table th { padding: 12px 10px; font-size: 13px; }
  .drink-compare-table .drink-row-label { font-size: 12px; white-space: normal; }
  .drink-compare-table td { min-width: 140px; }
  .drink-compare-col-head { padding: 20px 10px 16px; min-width: 140px; }
  .drink-compare-col-head h4 { font-size: 16px; }
  .drink-col-price { font-size: 13px; }
  .drink-col-rating { font-size: 11px; }
  .drink-compare-product-photo { max-width: 140px; }
  .drink-compare-table .drink-cat-row .drink-row-label { font-size: 14px; }
  .drink-btn-compare { padding: 12px 12px; font-size: 12px; }
}
@media (max-width: 480px) {
  .drink-compare h2 { font-size: 28px; }
  .drink-compare-table td { min-width: 120px; }
  .drink-compare-col-head { min-width: 120px; padding: 16px 8px 12px; }
  .drink-compare-col-head h4 { font-size: 14px; }
  .drink-compare-product-photo { max-width: 100px; }
  .drink-compare-table td, .drink-compare-table th { padding: 10px 8px; font-size: 12px; }
  .drink-compare-table .drink-row-label { font-size: 11px; }
  .drink-compare-toggle { max-width: 100%; }
}
</style>

<section class="drink-compare" id="drink-compare">
{%- assign ns = section.settings.metafield_namespace | default: 'custom' -%}
  <div class="drink-compare-eyebrow">{{ section.settings.eyebrow }}</div>
  <h2>{{ section.settings.heading }}</h2>
  <p>{{ section.settings.description }}</p>

  <!-- Model selector toggles -->
  <div class="drink-compare-selector">
    {% for block in section.blocks %}
      {%- assign p = block.settings.product -%}
      {%- assign c = block.settings.collection -%}
      {%- assign model_name = block.settings.name -%}
      {%- if model_name == blank and p != blank -%}{%- assign model_name = p.title -%}{%- endif -%}
      {%- if model_name == blank and c != blank -%}{%- assign model_name = c.title -%}{%- endif -%}
      <div class="drink-compare-toggle active" data-col="col-{{ forloop.index }}" onclick="drinkToggleCol('col-{{ forloop.index }}', this)" {{ block.shopify_attributes }}>
        <div class="drink-toggle-check">
          <svg width="14" height="14" fill="none" stroke="white" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <div class="drink-toggle-info">
          <div class="drink-toggle-name">{{ model_name }}</div>
          <div class="drink-toggle-tagline">{{ block.settings.tagline }}</div>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="drink-compare-hint">Select at least 2 flavors to compare</div>

  <!-- Comparison table -->
  <div class="drink-compare-table-wrap">
    <table class="drink-compare-table">
      <thead>
        <tr>
          <th class="drink-col-label"></th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign c = block.settings.collection -%}
            {%- assign model_name = block.settings.name -%}
            {%- if model_name == blank and p != blank -%}{%- assign model_name = p.title -%}{%- endif -%}
            {%- if model_name == blank and c != blank -%}{%- assign model_name = c.title -%}{%- endif -%}
            <th class="drink-col-col-{{ forloop.index }}">
              <div class="drink-compare-col-head{% if forloop.index > 2 %} drink-featured-head{% endif %}">
                {% if block.settings.image != blank %}
                  <img class="drink-compare-product-photo" src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ model_name }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="lazy">
                {% elsif p != blank and p.featured_image != blank %}
                  <img class="drink-compare-product-photo" src="{{ p.featured_image | image_url: width: 800 }}" alt="{{ model_name }}" width="{{ p.featured_image.width }}" height="{{ p.featured_image.height }}" loading="lazy">
                {% elsif c != blank and c.products.first != blank and c.products.first.featured_image != blank %}
                  <img class="drink-compare-product-photo" src="{{ c.products.first.featured_image | image_url: width: 800 }}" alt="{{ model_name }}" width="{{ c.products.first.featured_image.width }}" height="{{ c.products.first.featured_image.height }}" loading="lazy">
                {% elsif block.settings.image_url != blank %}
                  <img class="drink-compare-product-photo" src="{{ block.settings.image_url }}" alt="{{ model_name }}" loading="lazy">
                {% endif %}
                <h4>{{ model_name }}</h4>
                <div class="drink-col-price">
                  {% if block.settings.price != blank %}
                    {% if block.settings.original_price != blank %}
                      <span class="drink-price-now">{{ block.settings.price }}</span><span class="drink-price-was">{{ block.settings.original_price }}</span>
                    {% else %}
                      <strong>{{ block.settings.price }}</strong>
                    {% endif %}
                  {% elsif p != blank %}
                    {% if p.compare_at_price > p.price %}
                      <span class="drink-price-now">{{ p.price | money }}</span><span class="drink-price-was">{{ p.compare_at_price | money }}</span>
                    {% else %}
                      <strong>{{ p.price | money }}</strong>
                    {% endif %}
                  {% elsif c != blank and c.products.first != blank %}
                    {% if c.products.first.compare_at_price > c.products.first.price %}
                      <span class="drink-price-now">{{ c.products.first.price | money }}</span><span class="drink-price-was">{{ c.products.first.compare_at_price | money }}</span>
                    {% else %}
                      <strong>{{ c.products.first.price | money }}</strong>
                    {% endif %}
                  {% endif %}
                </div>
                <div class="drink-col-rating">
                  <span class="drink-stars-sm">&#9733;&#9733;&#9733;&#9733;&#9733;</span> {{ block.settings.rating }} · {{ block.settings.review_count }}
                </div>
              </div>
            </th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        <!-- NUTRITION -->
        <tr class="drink-cat-row">
          <th class="drink-row-label">Nutrition</th>
          {% for block in section.blocks %}
            <td class="drink-col-col-{{ forloop.index }}"></td>
          {% endfor %}
        </tr>
        <tr>
          <th class="drink-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>Sugar</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.sugar -%}
            {%- if v == blank and p != blank and p.metafields[ns].sugar != blank -%}{%- assign v = p.metafields[ns].sugar.value -%}{%- endif -%}
            <td class="drink-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="drink-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>Calories</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.calories -%}
            {%- if v == blank and p != blank and p.metafields[ns].calories != blank -%}{%- assign v = p.metafields[ns].calories.value -%}{%- endif -%}
            <td class="drink-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="drink-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"></path></svg>Servings</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.serving_size -%}
            {%- if v == blank and p != blank and p.metafields[ns].serving_size != blank -%}{%- assign v = p.metafields[ns].serving_size.value -%}{%- endif -%}
            <td class="drink-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>

        <!-- FORMULA -->
        <tr class="drink-cat-row">
          <th class="drink-row-label">Formula</th>
          {% for block in section.blocks %}
            <td class="drink-col-col-{{ forloop.index }}"></td>
          {% endfor %}
        </tr>
        <tr>
          <th class="drink-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"></path></svg>Electrolytes</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.electrolytes -%}
            {%- if v == blank and p != blank and p.metafields[ns].electrolytes != blank -%}{%- assign v = p.metafields[ns].electrolytes.value -%}{%- endif -%}
            <td class="drink-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="drink-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>Caffeine</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.caffeine -%}
            {%- if v == blank and p != blank and p.metafields[ns].caffeine != blank -%}{%- assign v = p.metafields[ns].caffeine.value -%}{%- endif -%}
            <td class="drink-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="drink-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>Keto</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.keto -%}
            {%- if v == blank and p != blank and p.metafields[ns].keto != blank -%}{%- assign v = p.metafields[ns].keto.value -%}{%- endif -%}
            <td class="drink-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>

        <!-- CTA ROW -->
        <tr class="drink-cta-row">
          <th></th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign c = block.settings.collection -%}
            {%- assign model_url = block.settings.button_url -%}
            {%- if model_url == blank and p != blank -%}{%- assign model_url = p.url -%}{%- endif -%}
            {%- if model_url == blank and c != blank -%}{%- assign model_url = c.url -%}{%- endif -%}
            {%- assign model_btn = block.settings.button_label -%}
            {%- if model_btn == blank and p != blank -%}{%- assign model_btn = 'Shop ' | append: p.title | append: ' →' -%}{%- endif -%}
            {%- if model_btn == blank and c != blank -%}{%- assign model_btn = 'Shop ' | append: c.title | append: ' →' -%}{%- endif -%}
            <td class="drink-col-col-{{ forloop.index }}">
              <a href="{{ model_url }}" class="drink-btn-compare">{{ model_btn }}</a>
            </td>
          {% endfor %}
        </tr>
      </tbody>
    </table>
  </div>
  <div class="drink-compare-scroll-hint">&larr; Scroll to see all flavors &rarr;</div>
</section>

<script>
// Compare table toggle functionality
function drinkToggleCol(colName, toggleEl) {
  var isActive = toggleEl.classList.contains('active');
  var activeCols = document.querySelectorAll('.drink-compare-toggle.active');
  // Require at least 2 columns visible
  if (isActive && activeCols.length <= 2) return;
  toggleEl.classList.toggle('active');
  var cells = document.querySelectorAll('.drink-compare-table .drink-col-' + colName);
  cells.forEach(function(cell) {
    cell.classList.toggle('drink-col-hidden');
  });
}
</script>

{% schema %}
{
  "name": "Drink Compare Flavors",
  "class": "section-drink-compare-flavors",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Compare"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Compare flavors."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Same base. Different taste."
    },
    {
      "type": "text",
      "id": "metafield_namespace",
      "label": "Metafield namespace",
      "default": "custom",
      "info": "Namespace for product metafields (e.g. 'custom'). Specs auto-fill from product.metafields.[namespace].[key]."
    }
  ],
  "blocks": [
    {
      "type": "model",
      "name": "Model",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Linked product",
          "info": "Auto-fills image, name, price, URL, and specs (via metafields). Manual settings below override."
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Linked collection",
          "info": "Use instead of product for collection pages (e.g. Variety Pack)."
        },
        {
          "type": "header",
          "content": "Model info"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Model name (override)"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "info": "Shown under the toggle name (e.g. \"Lightest · Belt Drive\")"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Model image (override)"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Model image URL (fallback)",
          "info": "Used when product image and image picker are both empty."
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price (override)",
          "info": "Displayed price (e.g. \"$1,999\"). Auto-filled from product if blank."
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "Original price (struck-through)",
          "info": "Leave blank if no sale. Auto-filled from product compare-at price if blank."
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Rating",
          "info": "e.g. \"4.91\""
        },
        {
          "type": "text",
          "id": "review_count",
          "label": "Review count",
          "info": "e.g. \"11 reviews\""
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "CTA button label (override)",
          "info": "Auto-filled from product if blank."
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "CTA button link (override)",
          "info": "Auto-filled from product URL if blank."
        },
        {
          "type": "header",
          "content": "Nutrition"
        },
        {
          "type": "text",
          "id": "sugar",
          "label": "Sugar",
          "info": "Auto-filled from product metafields if blank."
        },
        {
          "type": "text",
          "id": "calories",
          "label": "Calories",
