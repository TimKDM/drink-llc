{%- comment -%}
  Reviews with Background Image — wraps a Klaviyo reviews app block
  in a section with a background image, similar to home page style
{%- endcomment -%}

<div class="reviews-bg section-{{ section.id }}" style="
  {%- if section.settings.bg_image != blank -%}
    background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
  {%- endif -%}
  background-color: {{ section.settings.bg_color }};
">
  <div class="reviews-bg__overlay"></div>
  <div class="reviews-bg__content">
    {%- if section.settings.title != blank -%}
      <h2 class="reviews-bg__heading">{{ section.settings.title | escape }}</h2>
    {%- endif -%}
    <div class="reviews-bg__app">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          {% render block %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .reviews-bg.section-{{ section.id }} {
    position: relative;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    overflow: hidden;
  }

  .reviews-bg__overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .reviews-bg__content {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .reviews-bg__heading {
    font-family: var(--heading-font-family, 'DM Serif Display', serif);
    font-size: 36px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    text-align: center;
    margin: 0 0 32px;
  }

  @media (max-width: 768px) {
    .reviews-bg.section-{{ section.id }} {
      padding: {{ section.settings.padding_top | times: 0.6 | round }}px 0 {{ section.settings.padding_bottom | times: 0.6 | round }}px;
    }
    .reviews-bg__heading {
      font-size: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "Reviews with background",
  "class": "section-reviews-bg",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "What Riders Are Saying"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Reviews with background"
    }
  ]
}
{% endschema %}
