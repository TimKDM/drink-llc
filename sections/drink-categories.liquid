{%- style -%}
  #shopify-section-{{ section.id }} .drink-section {
    background-color: {{ section.settings.background_color }};
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
  }

  #shopify-section-{{ section.id }} .drink-section-label {
    color: {{ section.settings.accent_color }};
  }

  #shopify-section-{{ section.id }} .drink-section-title {
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .drink-category-card__content h3,
  #shopify-section-{{ section.id }} .drink-category-card__content p {
    color: {{ section.settings.text_color }};
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .drink-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="drink-section{% if section.settings.use_alt_bg %} drink-section-alt{% endif %}">
  <div class="drink-section-header">
    {%- if section.settings.caption != blank -%}
      <span class="drink-section-label">{{ section.settings.caption }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="drink-section-title">{{ section.settings.title }}</h2>
    {%- endif -%}
  </div>

  <div class="drink-category-grid">
    {%- for block in section.blocks -%}
      {%- assign collection = block.settings.collection -%}
      {%- if block.settings.link != blank -%}
        {%- assign card_url = block.settings.link -%}
      {%- elsif collection != blank -%}
        {%- assign card_url = collection.url -%}
      {%- else -%}
        {%- assign card_url = '#' -%}
      {%- endif -%}
      <a href="{{ card_url }}" class="drink-category-card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {%- assign card_image = block.settings.image -%}
        {%- elsif collection.image != blank -%}
          {%- assign card_image = collection.image -%}
        {%- elsif collection.products.first.featured_image != blank -%}
          {%- assign card_image = collection.products.first.featured_image -%}
        {%- else -%}
          {%- assign card_image = blank -%}
        {%- endif -%}

        {%- if card_image != blank -%}
          {{
            card_image
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              widths: '200, 300, 400, 600',
              sizes: '(min-width: 768px) 25vw, 50vw'
          }}
        {%- else -%}
          {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        <div class="drink-category-card__content">
          <h3>{{ block.settings.heading | default: collection.title }}</h3>
          {%- if block.settings.subtitle != blank -%}
            <p>{{ block.settings.subtitle }}</p>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Drink Categories",
  "tag": "section",
  "class": "drink-categories-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Find Your Thing"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Shop by Category"
    },
    {
      "type": "checkbox",
      "id": "use_alt_bg",
      "label": "Use alternate background",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image (optional)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Custom heading (optional)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link (overrides collection)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Drink Categories",
      "blocks": [
        { "type": "category", "settings": { "heading": "Matcha", "subtitle": "Ceremonial to everyday — all grades, all good" } },
        { "type": "category", "settings": { "heading": "Loose Leaf Tea", "subtitle": "Black, green, oolong, herbal — pick your mood" } },
        { "type": "category", "settings": { "heading": "Superfood Powders", "subtitle": "Mushroom, fruit, adaptogens — the good stuff" } },
        { "type": "category", "settings": { "heading": "Herbs & Spices", "subtitle": "Single origin, organic, honestly incredible" } }
      ]
    }
  ]
}
{% endschema %}
