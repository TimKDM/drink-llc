{% stylesheet %}
  /* =============================
     City Robin Icons (Scoped)
  ============================== */
  .cityrobin-icons-wrapper {
    max-width: 1200px;   /* keeps aligned with theme’s grid */
    margin: 0 auto;      /* center it */
    padding: 1.5rem 1rem; /* reduced vertical padding */
    box-sizing: border-box;
  }

  .cityrobin-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cityrobin-icons li {
    display: flex;
    align-items: flex-start;
    flex: 1 1 calc(25% - 20px); /* 4 per row on desktop */
    box-sizing: border-box;
  }

  .cityrobin-icons .icon-image {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    margin-right: 12px;
    margin-top: 2px;
  }

  .cityrobin-icons .icon-text {
    display: flex;
    flex-direction: column;
  }

  .cityrobin-icons .icon-title {
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 4px;
    color: #2E2E2E;
    line-height: 1.3;
  }

  .cityrobin-icons .icon-subtitle {
    font-size: 14px;
    font-weight: 400;
    color: #555;
    line-height: 1.4;
  }

  /* Responsive adjustments */
  @media screen and (max-width: 1024px) {
    .cityrobin-icons li {
      flex: 1 1 calc(33.333% - 20px); /* 3 per row on tablet */
    }
  }

  @media screen and (max-width: 768px) {
    .cityrobin-icons li {
      flex: 1 1 calc(50% - 20px); /* 2 per row on mobile */
    }
  }
{% endstylesheet %}

<div class="cityrobin-icons-wrapper">
  <ul class="cityrobin-icons">

    <li>
      <img 
        src="https://cdn.shopify.com/s/files/1/0577/5346/9110/files/range.svg?v=1730496961" 
