      <div class="icon-text">
        <div class="icon-title">Max Range</div>
        <div class="icon-subtitle">✅ Up to 60 miles per charge</div>
      </div>
    </li>

    <li>
      <img 
        src="https://cdn.shopify.com/s/files/1/0577/5346/9110/files/Speed.svg?v=1729093503" 
        alt="Speed Icon" 
        class="icon-image"
      >
      <div class="icon-text">
        <div class="icon-title">Top Speed</div>
        <div class="icon-subtitle">✅ 28 mph (Class 3 compliant)</div>
      </div>
    </li>

    <li>
      <img 
        src="https://cdn.shopify.com/s/files/1/0577/5346/9110/files/Hub.svg?v=1730490760" 
        alt="Motor Icon" 
        class="icon-image"
