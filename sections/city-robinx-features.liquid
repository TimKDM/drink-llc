      <div class="icon-text">
        <div class="icon-title">Motor</div>
        <div class="icon-subtitle">✅ 500W hub motor, throttle + pedal assist</div>
      </div>
    </li>

    <li>
      <img 
        src="https://cdn.shopify.com/s/files/1/0577/5346/9110/files/shimano.svg?v=1729093503" 
