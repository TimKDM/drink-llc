{%- style -%}
  .drink-trust-bar-section .drink-trust-bar {
    {% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
    {% if section.settings.border_color != blank and section.settings.border_color != 'rgba(0,0,0,0)' %}
      border-color: {{ section.settings.border_color }};
    {% endif %}
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  {% if section.settings.icon_color != blank and section.settings.icon_color != 'rgba(0,0,0,0)' %}
    .drink-trust-bar-section .drink-trust-item svg { stroke: {{ section.settings.icon_color }}; }
  {% endif %}
  {% if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' %}
    .drink-trust-bar-section .drink-trust-item span { color: {{ section.settings.text_color }}; }
    .drink-trust-bar-section .drink-trust-item strong { color: {{ section.settings.text_color }}; }
  {% endif %}
{%- endstyle -%}

<section class="drink-trust-bar">
  <div class="drink-trust-bar__inner">
    {%- for block in section.blocks -%}
      <div class="drink-trust-item" {{ block.shopify_attributes }}>
        {%- if block.settings.custom_image != blank -%}
          {{ block.settings.custom_image | image_url: width: 64 | image_tag: loading: 'lazy', width: 32, height: 32 }}
        {%- elsif block.settings.icon == 'shield' -%}
          <svg viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        {%- elsif block.settings.icon == 'package' -%}
          <svg viewBox="0 0 24 24"><path d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
        {%- elsif block.settings.icon == 'star' -%}
          <svg viewBox="0 0 24 24"><path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
        {%- elsif block.settings.icon == 'dollar' -%}
          <svg viewBox="0 0 24 24"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        {%- elsif block.settings.icon == 'leaf' -%}
          <svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66L7 18c4-2 6-5 7-9 1 4 3 7 7 9l1.36 4 1.82-.64C22.1 16.17 19.9 10.04 17 8z"></path></svg>
        {%- elsif block.settings.icon == 'truck' -%}
          <svg viewBox="0 0 24 24"><path d="M1 3h15v13H1V3zm15 6h4l3 3v4h-7V9zm-3 10a2 2 0 100-4 2 2 0 000 4zm10 0a2 2 0 100-4 2 2 0 000 4z"></path></svg>
        {%- elsif block.settings.icon == 'check' -%}
          <svg viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        {%- endif -%}
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" style="color:inherit;text-decoration:none;"><span>{{ block.settings.text }}</span></a>
        {%- else -%}
          <span>{{ block.settings.text }}</span>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "drink Trust Bar",
  "tag": "section",
  "class": "drink-trust-bar-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield / Certified" },
            { "value": "package", "label": "Package / Shipping" },
            { "value": "star", "label": "Star / Rating" },
            { "value": "dollar", "label": "Dollar / Pricing" },
            { "value": "leaf", "label": "Leaf / Organic" },
            { "value": "truck", "label": "Truck / Delivery" },
            { "value": "check", "label": "Check / Verified" }
          ],
          "default": "shield"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom icon image (overrides icon)"
        },
        {
          "type": "html",
          "id": "text",
          "label": "Text (supports <strong> tags)",
          "default": "<strong>USDA</strong> Certified Organic"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "drink Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "shield", "text": "<strong>USDA</strong> Certified Organic" } },
        { "type": "trust_item", "settings": { "icon": "package", "text": "<strong>Free Ship</strong> on $75+" } },
        { "type": "trust_item", "settings": { "icon": "leaf", "text": "<strong>Zero</strong> Additives. Ever." } },
        { "type": "trust_item", "settings": { "icon": "check", "text": "<strong>Every Batch</strong> Lab Tested" } }
      ]
    }
  ]
}
{% endschema %}
