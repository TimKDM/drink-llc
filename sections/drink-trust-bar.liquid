<!-- Drink Trust Bar Section — Fully editable via Theme Customizer -->
<style>
.drink-trust-bar {
  background: #FFFFFF;
  padding: 22px 48px;
  display: flex;
  justify-content: center;
  gap: 60px;
  flex-wrap: wrap;
  font-family: var(--base-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  box-sizing: border-box;
  border-bottom: 1px solid #EEEEEE;
}
.drink-trust-bar * { box-sizing: border-box; margin: 0; padding: 0; }
.drink-trust-item {
  display: flex;
  align-items: center;
  gap: 12px;
  color: #1A1A1A;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 0.3px;
  white-space: nowrap;
}
.drink-trust-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #FFF8E1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.drink-trust-item:nth-child(2) .drink-trust-icon { background: #FFE8F0; }
.drink-trust-item:nth-child(3) .drink-trust-icon { background: #FFF0E0; }
.drink-trust-item:nth-child(4) .drink-trust-icon { background: #F3E8FF; }
.drink-trust-item:nth-child(5) .drink-trust-icon { background: #E8F5E9; }
.drink-trust-icon svg { width: 20px; height: 20px; }
@media (max-width: 1024px) {
  .drink-trust-bar { gap: 32px; padding: 20px 32px; }
  .drink-trust-item { font-size: 14px; }
}
@media (max-width: 768px) {
  .drink-trust-bar { padding: 20px 16px; gap: 16px; flex-direction: column; align-items: center; }
  .drink-trust-item { font-size: 13px; gap: 10px; }
  .drink-trust-icon { width: 32px; height: 32px; }
  .drink-trust-icon svg { width: 16px; height: 16px; }
}
</style>

<div class="drink-trust-bar">
  {% for block in section.blocks %}
    <div class="drink-trust-item" {{ block.shopify_attributes }}>
      <div class="drink-trust-icon">
        {% case block.settings.icon %}
          {% when 'shield' %}
            <svg fill="none" stroke="#1A1A1A" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          {% when 'checkmark' %}
            <svg fill="none" stroke="#1A1A1A" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"></path><circle cx="12" cy="12" r="10"></circle></svg>
          {% when 'location' %}
            <svg fill="none" stroke="#1A1A1A" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          {% when 'people' %}
            <svg fill="none" stroke="#1A1A1A" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 00-3-3.87"></path><path d="M16 3.13a4 4 0 010 7.75"></path></svg>
          {% when 'star' %}
            <svg fill="none" stroke="#1A1A1A" stroke-width="2" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          {% when 'store' %}
            <svg fill="none" stroke="#1A1A1A" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          {% when 'texas' %}
            <svg fill="#1A1A1A" viewBox="0 0 24 24"><path d="M5 2L10 2L10 8L13 8L15 10L17 12L18 14L19 16L18.5 17.5L16.5 19L14.5 20.5L12.5 21.5L10.5 20.5L8.5 21L6.5 18.5L5.5 15.5L5 12Z"/></svg>
          {% when 'leaf' %}
            <svg fill="none" stroke="#1A1A1A" stroke-width="2" viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75"></path></svg>
          {% when 'droplet' %}
            <svg fill="none" stroke="#1A1A1A" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"></path></svg>
          {% when 'heart' %}
            <svg fill="none" stroke="#1A1A1A" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"></path></svg>
          {% when 'truck' %}
            <svg fill="none" stroke="#1A1A1A" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"></rect><path d="M16 8h4l3 5v3h-7V8z"></path><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
        {% endcase %}
      </div>
      {{ block.settings.text }}
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Drink Trust Bar",
  "class": "section-drink-trust-bar",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield" },
            { "value": "checkmark", "label": "Checkmark" },
            { "value": "location", "label": "Location" },
            { "value": "people", "label": "People" },
            { "value": "star", "label": "Star" },
            { "value": "store", "label": "Store" },
            { "value": "texas", "label": "Texas" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "droplet", "label": "Droplet" },
            { "value": "heart", "label": "Heart" },
            { "value": "truck", "label": "Truck" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trust message"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Drink Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "checkmark",
            "text": "KETO"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "shield",
            "text": "SUGAR FREE"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "leaf",
            "text": "CAFFEINE FREE"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "droplet",
            "text": "ELECTROLYTES"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "heart",
            "text": "NO FILLERS"
          }
        }
      ]
    }
  ]
}
{% endschema %}
