          {% for block in section.blocks %}
            <td class="euphree-col-col-{{ forloop.index }}"></td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>Ideal Rider</th>
