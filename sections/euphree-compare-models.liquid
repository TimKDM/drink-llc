<!-- Euphree Compare Models Section — Shopify Online Store 2.0 -->
<!-- Interactive toggle comparison table with dynamic model blocks -->
<!-- NOTE: This section includes JavaScript for the toggle functionality -->
<style>
.euphree-compare {
  padding: 100px 48px;
  background: #f5f5f3;
  text-align: center;
  font-family: var(--base-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  box-sizing: border-box;
}
.euphree-compare * { box-sizing: border-box; margin: 0; padding: 0; }
.euphree-compare-eyebrow {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #888888;
  margin-bottom: 16px;
}
.euphree-compare h2 {
  font-family: var(--heading-font-family), serif;
  font-size: 52px;
  font-weight: 700;
  margin-bottom: 16px;
  color: #121212;
}
.euphree-compare > p {
  font-size: 18px;
  color: #555555;
  margin-bottom: 48px;
}

/* Model selector toggles */
.euphree-compare-selector {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-bottom: 48px;
  flex-wrap: wrap;
}
.euphree-compare-toggle {
  display: flex;
  align-items: center;
  gap: 12px;
  background: #ffffff;
  border: 2px solid transparent;
  border-radius: 12px;
  padding: 16px 24px;
  cursor: pointer;
  transition: all 0.25s;
  user-select: none;
}
.euphree-compare-toggle:hover { border-color: #c0c0c0; }
.euphree-compare-toggle.active { border-color: #2e72d2; box-shadow: 0 4px 20px rgba(46,114,210,0.15); }
.euphree-toggle-check {
  width: 24px;
  height: 24px;
  border-radius: 6px;
  border: 2px solid #c0c0c0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  flex-shrink: 0;
}
.euphree-compare-toggle.active .euphree-toggle-check {
  background: #2e72d2;
  border-color: #2e72d2;
}
.euphree-toggle-check svg { opacity: 0; transition: opacity 0.15s; }
.euphree-compare-toggle.active .euphree-toggle-check svg { opacity: 1; }
.euphree-toggle-info { text-align: left; }
.euphree-toggle-name {
  font-family: var(--heading-font-family), serif;
  font-size: 18px;
  font-weight: 700;
  color: #121212;
}
.euphree-toggle-tagline {
  font-size: 13px;
  color: #888888;
  margin-top: 2px;
}
.euphree-compare-hint {
  font-size: 14px;
  color: #888888;
  margin-bottom: 32px;
}

/* Comparison table */
.euphree-compare-table-wrap {
  max-width: 1400px;
  margin: 0 auto;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.euphree-compare-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  text-align: left;
}
.euphree-compare-table thead th {
  position: sticky;
  top: 72px;
  background: #f5f5f3;
  z-index: 5;
  padding: 0 16px 20px;
  vertical-align: bottom;
}
.euphree-compare-table th.euphree-col-label { width: 180px; min-width: 160px; }
.euphree-compare-col-head {
  background: #ffffff;
  border-radius: 16px 16px 0 0;
  padding: 28px 16px 20px;
  text-align: center;
  min-width: 200px;
}
.euphree-compare-bike-photo {
  width: 100%;
  max-width: 200px;
  height: auto;
  margin: 0 auto 12px;
  display: block;
  filter: drop-shadow(0 4px 12px rgba(0,0,0,0.1));
}
.euphree-compare-col-head h4 {
  font-family: var(--heading-font-family), serif;
  font-size: 22px;
  font-weight: 700;
  color: #121212;
  margin-bottom: 4px;
}
.euphree-col-price {
  font-size: 15px;
  color: #555555;
  font-weight: 600;
}
.euphree-col-price .euphree-price-was {
  text-decoration: line-through;
  color: #c0c0c0;
  font-weight: 400;
  margin-left: 6px;
}
.euphree-col-price .euphree-price-now { color: #c0392b; font-weight: 800; }
.euphree-col-rating {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-top: 8px;
  font-size: 13px;
  color: #555555;
}
.euphree-col-rating .euphree-stars-sm { color: #b8963e; font-size: 15px; letter-spacing: 1px; }

/* Table body */
.euphree-compare-table tbody tr { transition: background 0.15s; }
.euphree-compare-table tbody tr:hover { background: rgba(0,0,0,0.015); }
.euphree-compare-table td, .euphree-compare-table th {
  padding: 16px;
  font-size: 15px;
  border-bottom: 1px solid rgba(0,0,0,0.06);
  vertical-align: middle;
}
.euphree-compare-table .euphree-row-label {
  font-weight: 700;
  color: #333333;
  font-size: 14px;
  letter-spacing: 0.3px;
  white-space: nowrap;
}
.euphree-compare-table .euphree-row-label svg { width: 16px; height: 16px; opacity: 0.4; margin-right: 8px; vertical-align: -2px; }
.euphree-compare-table td {
  text-align: center;
  color: #555555;
  font-weight: 500;
  min-width: 200px;
}
.euphree-compare-table td strong { color: #121212; font-weight: 700; }

/* Category header rows */
.euphree-compare-table .euphree-cat-row td, .euphree-compare-table .euphree-cat-row th {
  padding-top: 28px;
  border-bottom: 2px solid rgba(0,0,0,0.1);
}
.euphree-compare-table .euphree-cat-row .euphree-row-label {
  font-family: var(--heading-font-family), serif;
  font-size: 18px;
  font-weight: 700;
  color: #121212;
  letter-spacing: 0;
}

/* CTA row */
.euphree-compare-table .euphree-cta-row td {
  padding: 24px 16px 32px;
  border-bottom: none;
  text-align: center;
}
.euphree-btn-compare {
  display: inline-block;
  background: #2e72d2;
  color: #ffffff;
  padding: 14px 16px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.2s;
  text-align: center;
  white-space: nowrap;
}
.euphree-btn-compare:hover {
  background: #333333;
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.15);
}

/* Column visibility */
.euphree-compare-table .euphree-col-hidden { display: none; }

/* Falcon column header accent */
.euphree-compare-col-head.euphree-falcon-head {
  background: linear-gradient(180deg, #ffffff 0%, #fafaf8 100%);
}

/* Mobile scroll hint */
.euphree-compare-scroll-hint {
  display: none;
  text-align: center;
  font-size: 13px;
  color: #888888;
  margin-top: 12px;
}
@media (max-width: 900px) {
  .euphree-compare-scroll-hint { display: block; }
  .euphree-compare-selector { gap: 10px; }
  .euphree-compare-toggle { padding: 12px 16px; }
  .euphree-toggle-name { font-size: 16px; }
}

/* Tablet */
@media (max-width: 1024px) {
  .euphree-compare h2 { font-size: 40px; }
}
/* Mobile */
@media (max-width: 768px) {
  .euphree-compare { padding: 64px 20px; }
  .euphree-compare h2 { font-size: 32px; }
  .euphree-compare > p { font-size: 15px; margin-bottom: 32px; }
  .euphree-compare-selector { gap: 8px; flex-direction: column; align-items: center; }
  .euphree-compare-toggle { padding: 12px 16px; width: 100%; max-width: 320px; }
  .euphree-toggle-name { font-size: 15px; }
  .euphree-toggle-tagline { font-size: 12px; }
  .euphree-compare-hint { font-size: 13px; margin-bottom: 20px; }
  .euphree-compare-table td, .euphree-compare-table th { padding: 12px 10px; font-size: 13px; }
  .euphree-compare-table .euphree-row-label { font-size: 12px; white-space: normal; }
  .euphree-compare-table td { min-width: 140px; }
  .euphree-compare-col-head { padding: 20px 10px 16px; min-width: 140px; }
  .euphree-compare-col-head h4 { font-size: 16px; }
  .euphree-col-price { font-size: 13px; }
  .euphree-col-rating { font-size: 11px; }
  .euphree-compare-bike-photo { max-width: 140px; }
  .euphree-compare-table .euphree-cat-row .euphree-row-label { font-size: 14px; }
  .euphree-btn-compare { padding: 12px 12px; font-size: 12px; }
}
@media (max-width: 480px) {
  .euphree-compare h2 { font-size: 28px; }
  .euphree-compare-table td { min-width: 120px; }
  .euphree-compare-col-head { min-width: 120px; padding: 16px 8px 12px; }
  .euphree-compare-col-head h4 { font-size: 14px; }
  .euphree-compare-bike-photo { max-width: 100px; }
  .euphree-compare-table td, .euphree-compare-table th { padding: 10px 8px; font-size: 12px; }
  .euphree-compare-table .euphree-row-label { font-size: 11px; }
  .euphree-compare-toggle { max-width: 100%; }
}
</style>

<section class="euphree-compare" id="euphree-compare">
{%- assign ns = section.settings.metafield_namespace | default: 'custom' -%}
  <div class="euphree-compare-eyebrow">{{ section.settings.eyebrow }}</div>
  <h2>{{ section.settings.heading }}</h2>
  <p>{{ section.settings.description }}</p>

  <!-- Model selector toggles -->
  <div class="euphree-compare-selector">
    {% for block in section.blocks %}
      {%- assign p = block.settings.product -%}
      {%- assign c = block.settings.collection -%}
      {%- assign model_name = block.settings.name -%}
      {%- if model_name == blank and p != blank -%}{%- assign model_name = p.title -%}{%- endif -%}
      {%- if model_name == blank and c != blank -%}{%- assign model_name = c.title -%}{%- endif -%}
      <div class="euphree-compare-toggle active" data-col="col-{{ forloop.index }}" onclick="euphreeToggleCol('col-{{ forloop.index }}', this)" {{ block.shopify_attributes }}>
        <div class="euphree-toggle-check">
          <svg width="14" height="14" fill="none" stroke="white" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <div class="euphree-toggle-info">
          <div class="euphree-toggle-name">{{ model_name }}</div>
          <div class="euphree-toggle-tagline">{{ block.settings.tagline }}</div>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="euphree-compare-hint">Select at least 2 models to compare</div>

  <!-- Comparison table -->
  <div class="euphree-compare-table-wrap">
    <table class="euphree-compare-table">
      <thead>
        <tr>
          <th class="euphree-col-label"></th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign c = block.settings.collection -%}
            {%- assign model_name = block.settings.name -%}
            {%- if model_name == blank and p != blank -%}{%- assign model_name = p.title -%}{%- endif -%}
            {%- if model_name == blank and c != blank -%}{%- assign model_name = c.title -%}{%- endif -%}
            <th class="euphree-col-col-{{ forloop.index }}">
              <div class="euphree-compare-col-head{% if forloop.index > 2 %} euphree-falcon-head{% endif %}">
                {% if block.settings.image != blank %}
                  <img class="euphree-compare-bike-photo" src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ model_name }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="lazy">
                {% elsif p != blank and p.featured_image != blank %}
                  <img class="euphree-compare-bike-photo" src="{{ p.featured_image | image_url: width: 800 }}" alt="{{ model_name }}" width="{{ p.featured_image.width }}" height="{{ p.featured_image.height }}" loading="lazy">
                {% elsif c != blank and c.products.first != blank and c.products.first.featured_image != blank %}
                  <img class="euphree-compare-bike-photo" src="{{ c.products.first.featured_image | image_url: width: 800 }}" alt="{{ model_name }}" width="{{ c.products.first.featured_image.width }}" height="{{ c.products.first.featured_image.height }}" loading="lazy">
                {% elsif block.settings.image_url != blank %}
                  <img class="euphree-compare-bike-photo" src="{{ block.settings.image_url }}" alt="{{ model_name }}" loading="lazy">
                {% endif %}
                <h4>{{ model_name }}</h4>
                <div class="euphree-col-price">
                  {% if block.settings.price != blank %}
                    {% if block.settings.original_price != blank %}
                      <span class="euphree-price-now">{{ block.settings.price }}</span><span class="euphree-price-was">{{ block.settings.original_price }}</span>
                    {% else %}
                      <strong>{{ block.settings.price }}</strong>
                    {% endif %}
                  {% elsif p != blank %}
                    {% if p.compare_at_price > p.price %}
                      <span class="euphree-price-now">{{ p.price | money }}</span><span class="euphree-price-was">{{ p.compare_at_price | money }}</span>
                    {% else %}
                      <strong>{{ p.price | money }}</strong>
                    {% endif %}
                  {% elsif c != blank and c.products.first != blank %}
                    {% if c.products.first.compare_at_price > c.products.first.price %}
                      <span class="euphree-price-now">{{ c.products.first.price | money }}</span><span class="euphree-price-was">{{ c.products.first.compare_at_price | money }}</span>
                    {% else %}
                      <strong>{{ c.products.first.price | money }}</strong>
                    {% endif %}
                  {% endif %}
                </div>
                <div class="euphree-col-rating">
                  <span class="euphree-stars-sm">&#9733;&#9733;&#9733;&#9733;&#9733;</span> {{ block.settings.rating }} · {{ block.settings.review_count }}
                </div>
              </div>
            </th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        <!-- POWER & RANGE -->
        <tr class="euphree-cat-row">
          <th class="euphree-row-label">Power &amp; Range</th>
          {% for block in section.blocks %}
            <td class="euphree-col-col-{{ forloop.index }}"></td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>Motor</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.motor -%}
            {%- if v == blank and p != blank and p.metafields[ns].motor != blank -%}{%- assign v = p.metafields[ns].motor.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>Peak Power</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.peak_power -%}
            {%- if v == blank and p != blank and p.metafields[ns].peak_power != blank -%}{%- assign v = p.metafields[ns].peak_power.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>Torque</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.torque -%}
            {%- if v == blank and p != blank and p.metafields[ns].torque != blank -%}{%- assign v = p.metafields[ns].torque.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="6" width="18" height="12" rx="2"></rect><path d="M23 13v-2"></path></svg>Battery</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.battery -%}
            {%- if v == blank and p != blank and p.metafields[ns].battery != blank -%}{%- assign v = p.metafields[ns].battery.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>Range</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.range -%}
            {%- if v == blank and p != blank and p.metafields[ns].range != blank -%}{%- assign v = p.metafields[ns].range.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 17l5-5-5-5M6 17l5-5-5-5"></path></svg>Top Speed</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.top_speed -%}
            {%- if v == blank and p != blank and p.metafields[ns].top_speed != blank -%}{%- assign v = p.metafields[ns].top_speed.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>Sensor</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.sensor -%}
            {%- if v == blank and p != blank and p.metafields[ns].sensor != blank -%}{%- assign v = p.metafields[ns].sensor.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>

        <!-- COMFORT & SUSPENSION -->
        <tr class="euphree-cat-row">
          <th class="euphree-row-label">Comfort &amp; Suspension</th>
          {% for block in section.blocks %}
            <td class="euphree-col-col-{{ forloop.index }}"></td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22V8M5 12H2a10 10 0 0020 0h-3"></path></svg>Front Fork</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.front_fork -%}
            {%- if v == blank and p != blank and p.metafields[ns].front_fork != blank -%}{%- assign v = p.metafields[ns].front_fork.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v20M2 12h20"></path></svg>Seatpost</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.seatpost -%}
            {%- if v == blank and p != blank and p.metafields[ns].seatpost != blank -%}{%- assign v = p.metafields[ns].seatpost.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle></svg>Tires</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.tires -%}
            {%- if v == blank and p != blank and p.metafields[ns].tires != blank -%}{%- assign v = p.metafields[ns].tires.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"></path></svg>Drivetrain</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.drivetrain -%}
            {%- if v == blank and p != blank and p.metafields[ns].drivetrain != blank -%}{%- assign v = p.metafields[ns].drivetrain.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>
        <tr>
          <th class="euphree-row-label"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M12 1v6m0 6v6m-7-7h6m6 0h6"></path></svg>Brakes</th>
          {% for block in section.blocks %}
            {%- assign p = block.settings.product -%}
            {%- assign v = block.settings.brakes -%}
            {%- if v == blank and p != blank and p.metafields[ns].brakes != blank -%}{%- assign v = p.metafields[ns].brakes.value -%}{%- endif -%}
            <td class="euphree-col-col-{{ forloop.index }}">{{ v }}</td>
          {% endfor %}
        </tr>

        <!-- FIT & GEOMETRY -->
        <tr class="euphree-cat-row">
          <th class="euphree-row-label">Fit &amp; Geometry</th>
          {% for block in section.blocks %}
