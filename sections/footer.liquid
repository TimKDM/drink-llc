{%- comment -%} Drink LLC — Footer Section {%- endcomment -%}

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">

      <div class="site-footer__brand">
        <span class="site-footer__wordmark">{{ shop.name }}</span>
        <p class="site-footer__tagline">{{ section.settings.tagline | default: 'Just Drink.' }}</p>
      </div>

      {%- if section.settings.menu != blank -%}
        <nav class="site-footer__nav" aria-label="Footer navigation">
          <span class="label">Navigate</span>
          <ul role="list">
            {%- for link in section.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}

      <div class="site-footer__social">
        <span class="label">Follow</span>
        <ul role="list">
          {%- if settings.social_instagram != blank -%}
            <li><a href="{{ settings.social_instagram }}" target="_blank" rel="noopener">Instagram</a></li>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <li><a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener">TikTok</a></li>
          {%- endif -%}
          {%- if settings.social_twitter != blank -%}
            <li><a href="{{ settings.social_twitter }}" target="_blank" rel="noopener">X</a></li>
          {%- endif -%}
        </ul>
      </div>

    </div>

    <div class="site-footer__bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 0.5px solid var(--color-carbon);
    padding: var(--space-2xl) 0 var(--space-xl);
    background-color: var(--color-void);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  .site-footer__wordmark {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-offwhite);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .site-footer__tagline {
    color: var(--color-ash);
    font-size: 0.9rem;
  }

  .site-footer__nav .label,
  .site-footer__social .label {
    display: block;
    margin-bottom: var(--space-md);
  }

  .site-footer__nav ul,
  .site-footer__social ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .site-footer__nav a,
  .site-footer__social a {
    color: var(--color-ash);
    font-size: 0.9rem;
    font-weight: 300;
    transition: color var(--transition-fast);
  }

  .site-footer__nav a:hover,
  .site-footer__social a:hover {
    color: var(--color-offwhite);
    opacity: 1;
  }

  .site-footer__bottom {
    border-top: 0.5px solid var(--color-carbon);
    padding-top: var(--space-lg);
  }

  .site-footer__bottom p {
    font-size: 0.8rem;
    color: var(--color-ash);
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Just Drink."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu",
      "default": "footer"
    }
  ]
}
{% endschema %}
