<!-- Euphree Trust Bar Section — Fully editable via Theme Customizer -->
<style>
.euphree-trust-bar {
  background: linear-gradient(135deg, #1a3d6e 0%, #1e4f8a 50%, #2e72d2 100%);
  padding: 22px 48px;
  display: flex;
  justify-content: center;
  gap: 60px;
  flex-wrap: wrap;
  font-family: var(--base-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  box-sizing: border-box;
}
.euphree-trust-bar * { box-sizing: border-box; margin: 0; padding: 0; }
.euphree-trust-item {
  display: flex;
  align-items: center;
  gap: 12px;
  color: #ffffff;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 0.3px;
  white-space: nowrap;
}
.euphree-trust-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.euphree-trust-icon svg { width: 20px; height: 20px; }
@media (max-width: 1024px) {
  .euphree-trust-bar { gap: 32px; padding: 20px 32px; }
  .euphree-trust-item { font-size: 14px; }
}
@media (max-width: 768px) {
  .euphree-trust-bar { padding: 20px 16px; gap: 16px; flex-direction: column; align-items: center; }
  .euphree-trust-item { font-size: 13px; gap: 10px; }
  .euphree-trust-icon { width: 32px; height: 32px; }
  .euphree-trust-icon svg { width: 16px; height: 16px; }
}
</style>

<div class="euphree-trust-bar">
  {% for block in section.blocks %}
    <div class="euphree-trust-item" {{ block.shopify_attributes }}>
      <div class="euphree-trust-icon">
        {% case block.settings.icon %}
          {% when 'shield' %}
            <svg fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          {% when 'checkmark' %}
            <svg fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"></path><circle cx="12" cy="12" r="10"></circle></svg>
          {% when 'location' %}
            <svg fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          {% when 'people' %}
            <svg fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 00-3-3.87"></path><path d="M16 3.13a4 4 0 010 7.75"></path></svg>
          {% when 'star' %}
            <svg fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          {% when 'store' %}
            <svg fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          {% when 'texas' %}
            <svg fill="white" viewBox="0 0 24 24"><path d="M5 2L10 2L10 8L13 8L15 10L17 12L18 14L19 16L18.5 17.5L16.5 19L14.5 20.5L12.5 21.5L10.5 20.5L8.5 21L6.5 18.5L5.5 15.5L5 12Z"/></svg>
        {% endcase %}
      </div>
      {{ block.settings.text }}
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Euphree Trust Bar",
  "class": "section-euphree-trust-bar",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield" },
            { "value": "checkmark", "label": "Checkmark" },
            { "value": "location", "label": "Location" },
            { "value": "people", "label": "People" },
            { "value": "star", "label": "Star" },
            { "value": "store", "label": "Store" },
            { "value": "texas", "label": "Texas" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trust message"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Euphree Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "shield",
            "text": "SGS Certified Quality"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "checkmark",
            "text": "2-Year Warranty"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "location",
            "text": "Houston, Texas"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "people",
            "text": "180+ Dealers Nationwide"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "star",
            "text": "5,000+ Happy Riders"
          }
        }
      ]
    }
  ]
}
{% endschema %}
