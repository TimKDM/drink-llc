{%- comment -%} Drink LLC — Header Section {%- endcomment -%}

<header class="site-header" role="banner">
  <div class="container">
    <nav class="site-header__nav" aria-label="Main navigation">

      {%- comment -%} Logo / Wordmark {%- endcomment -%}
      <a href="/" class="site-header__logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 240 }}"
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_width | default: 120 }}"
            loading="eager"
          >
        {%- else -%}
          <img
            src="{{ 'logo-drink.svg' | asset_url }}"
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_width | default: 120 }}"
            loading="eager"
          >
        {%- endif -%}
      </a>

      {%- comment -%} Navigation Links {%- endcomment -%}
      <ul class="site-header__links" role="list">
        {%- for link in section.settings.menu.links -%}
          <li>
            <a href="{{ link.url }}" class="site-header__link label">
              {{ link.title }}
            </a>
          </li>
        {%- endfor -%}
      </ul>

      {%- comment -%} Cart Link {%- endcomment -%}
      <a href="/cart" class="site-header__cart label" aria-label="Cart ({{ cart.item_count }})">
        Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}
      </a>

      {%- comment -%} Mobile Menu Toggle {%- endcomment -%}
      <button class="site-header__menu-toggle" aria-label="Menu" aria-expanded="false">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <line x1="4" y1="7" x2="20" y2="7"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="17" x2="20" y2="17"/>
        </svg>
      </button>

    </nav>
  </div>
</header>

{%- comment -%} Mobile Navigation Drawer {%- endcomment -%}
<div class="mobile-nav" aria-hidden="true">
  <div class="mobile-nav__inner">
    <ul class="mobile-nav__links" role="list">
      {%- for link in section.settings.menu.links -%}
        <li>
          <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
        </li>
      {%- endfor -%}
      <li>
        <a href="/cart" class="mobile-nav__link">
          Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}
        </a>
      </li>
    </ul>
  </div>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-void);
    border-bottom: 0.5px solid var(--color-carbon);
    padding: var(--space-md) 0;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-header__wordmark {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-offwhite);
  }

  .site-header__logo img {
    height: auto;
  }

  .site-header__links {
    display: flex;
    gap: var(--space-lg);
    list-style: none;
  }

  .site-header__link {
    transition: opacity var(--transition-fast);
  }

  .site-header__link:hover {
    opacity: 0.7;
  }

  .site-header__cart {
    color: var(--color-offwhite);
  }

  .site-header__menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--color-offwhite);
    cursor: pointer;
    padding: var(--space-xs);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .site-header__links {
      display: none;
    }

    .site-header__cart {
      display: none;
    }

    .site-header__menu-toggle {
      display: block;
    }
  }

  .mobile-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--color-void);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base);
  }

  .mobile-nav.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-nav__links {
    list-style: none;
    text-align: center;
  }

  .mobile-nav__link {
    font-family: var(--font-display);
    font-size: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
    padding: var(--space-md);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var toggle = document.querySelector('.site-header__menu-toggle');
    var mobileNav = document.querySelector('.mobile-nav');

    if (!toggle || !mobileNav) return;

    toggle.addEventListener('click', function() {
      var isOpen = mobileNav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', isOpen);
      mobileNav.setAttribute('aria-hidden', !isOpen);
    });
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 60,
      "max": 200,
      "step": 10,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
