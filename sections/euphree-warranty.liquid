<!-- Euphree Warranty Section -->
<!-- 2-column: warranty features + CTA left, visual placeholder right -->
<style>
.euphree-warranty {
  padding: 120px 48px;
  background: #ffffff;
  font-family: var(--base-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  box-sizing: border-box;
}
.euphree-warranty * { box-sizing: border-box; margin: 0; padding: 0; }
.euphree-warranty-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  max-width: 1300px;
  margin: 0 auto;
}
.euphree-warranty-eyebrow {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: #888888;
  margin-bottom: 16px;
}
.euphree-warranty-content h2 {
  font-family: var(--heading-font-family), serif;
  font-size: 52px;
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 24px;
  color: #121212;
}
.euphree-warranty-content p {
  font-size: 18px;
  line-height: 1.7;
  color: #555555;
  margin-bottom: 32px;
}
.euphree-warranty-features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 40px;
}
.euphree-warranty-feat {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}
.euphree-warranty-feat svg { width: 24px; height: 24px; color: #1a4d2e; flex-shrink: 0; margin-top: 2px; }
.euphree-warranty-feat-text strong { display: block; font-size: 15px; margin-bottom: 2px; color: #121212; }
.euphree-warranty-feat-text span { font-size: 14px; color: #888888; }
.euphree-warranty-visual {
  aspect-ratio: 4/3;
  border-radius: 20px;
  overflow: hidden;
}
.euphree-warranty-visual img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
/* Placeholder state — remove when you have a real photo */
.euphree-warranty-visual-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 12px;
  background: linear-gradient(135deg, #e8e2d8, #d8cfc2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 40px;
  text-align: center;
}
.euphree-warranty-visual-placeholder svg { margin-bottom: 12px; }
.euphree-warranty-visual-placeholder p {
  color: rgba(0,0,0,0.5);
  font-size: 14px;
  margin-top: 16px;
  font-weight: 600;
  margin-bottom: 0;
}
.euphree-warranty .euphree-btn-warranty {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #2e72d2;
  color: #ffffff;
  padding: 18px 36px;
  border-radius: 8px;
  font-size: 17px;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.25s;
}
.euphree-warranty .euphree-btn-warranty:hover {
  background: #2563b8;
  transform: translateY(-2px);
}

/* Tablet */
@media (max-width: 1024px) {
  .euphree-warranty-grid { grid-template-columns: 1fr; gap: 48px; }
  .euphree-warranty-content h2 { font-size: 40px; }
}
/* Mobile */
@media (max-width: 768px) {
  .euphree-warranty { padding: 64px 20px; }
  .euphree-warranty-grid { gap: 40px; }
  .euphree-warranty-content h2 { font-size: 32px; }
  .euphree-warranty-content p { font-size: 16px; }
  .euphree-warranty-features { grid-template-columns: 1fr; gap: 16px; }
  .euphree-warranty-feat-text strong { font-size: 14px; }
  .euphree-warranty-feat-text span { font-size: 13px; }
}
@media (max-width: 480px) {
  .euphree-warranty-content h2 { font-size: 28px; }
}
</style>

<section class="euphree-warranty">
  <div class="euphree-warranty-grid">
    <div class="euphree-warranty-content">
      <div class="euphree-warranty-eyebrow">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
      <div class="euphree-warranty-features">
        {% for block in section.blocks %}
          {% if block.type == 'feature' %}
            <div class="euphree-warranty-feat" {{ block.shopify_attributes }}>
              <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <div class="euphree-warranty-feat-text">
                <strong>{{ block.settings.title }}</strong>
                <span>{{ block.settings.description }}</span>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      {% if section.settings.phone_number != blank %}
        <a href="tel:{{ section.settings.phone_number | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}" class="euphree-btn-warranty">{{ section.settings.button_label }}</a>
      {% elsif section.settings.button_url != blank %}
        <a href="{{ section.settings.button_url }}" class="euphree-btn-warranty">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
    <div class="euphree-warranty-visual">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url: width: 1024 }}" alt="{{ section.settings.heading }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="lazy">
      {% else %}
        <div class="euphree-warranty-visual-placeholder">
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="rgba(0,0,0,0.15)" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"></path></svg>
          <p>Add an image in the theme editor</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Euphree Warranty",
  "class": "section-euphree-warranty",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Peace of Mind"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We've Got Your Back — Literally"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every Euphree comes with a comprehensive 2-year warranty and Houston-based customer support from people who actually ride ebikes."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Call Us: (866) 729-8075 →"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number (click-to-call)",
      "info": "Enter the phone number for the click-to-call link (e.g. 8667298075). Leave blank to use Button URL instead.",
      "default": "8667298075"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL",
      "info": "Only used if Phone Number is blank."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Warranty Image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Feature description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Euphree Warranty",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "2-Year Full Warranty",
            "description": "Frame, motor, battery & components"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Houston-Based Support",
            "description": "Real humans, not chatbots"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Spare Parts Available",
            "description": "Easy replacement when you need it"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "180+ Service Locations",
            "description": "Local dealer warranty work"
          }
        }
      ]
    }
  ]
}
{% endschema %}
