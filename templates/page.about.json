        },
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "<p>Where purity meets performance — that's not a tagline, it's just <em>science</em>.</p>",
            "heading_size": "large",
            "heading_style": "default",
            "heading_tag": "h2",
            "highlight_option": "underline-hand",
            "word_animation_color": "#d4c4d9"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>We built Drink Ingredients for people who want to know what's in their food — and who's behind it. We work directly with organic farms across Japan, India, Sri Lanka, and beyond because we think the relationship between grower and maker matters just as much as the ingredient itself.</p>"
          }
        }
      },
