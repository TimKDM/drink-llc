          "type": "column",
          "settings": {
            "image": "",
            "hide_image": false,
            "title": "USDA Organic · CCOF Certified",
            "text": "<p>Every product we carry is USDA certified organic and CCOF certified — no pesticides, no GMOs, no synthetics. We don't just say it, we prove it. Full documentation, always available.</p>",
            "link_label": "",
            "link": ""
          }
