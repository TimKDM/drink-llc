        "column_2": {
          "type": "column",
          "settings": {
            "image": "",
            "hide_image": false,
            "title": "Independently Lab Tested",
            "text": "<p>Every batch gets tested by third-party labs for purity, potency, heavy metals, and allergens. We test because facts matter — and so does your trust.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_3": {
          "type": "column",
          "settings": {
            "image": "",
            "hide_image": false,
            "title": "Trusted by People Who Care",
            "text": "<p>Home kitchens, professional cafés, wellness brands — our community is made up of people who refuse to settle. We're proud to be their go-to.</p>",
            "link_label": "",
            "link": ""
          }
        }
