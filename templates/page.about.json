            "heading_style": "default",
            "heading_tag": "h2"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>We go direct. We visit farms, build long-term relationships with growers, and maintain full traceability on every ingredient. Every batch is independently lab-tested for purity and safety. No middlemen padding things out, no mystery ingredients sneaking in. What you see is what you get — and what you get is really, really good.</p>"
          }
        },
        "button": {
          "type": "button",
          "settings": {
