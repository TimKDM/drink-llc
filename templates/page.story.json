{"sections":{"main":{"type":"main-page","disabled":true,"settings":{"show_page_title":true,"full_width":false}},"cdffcd03-a94b-4d6e-a504-1fe0b70347d6":{"type":"image-with-text-overlay","blocks":{"template--15213462618185__cdffcd03-a94b-4d6e-a504-1fe0b70347d6-subheading-1":{"type":"subheading","settings":{"subheading":"Built On Real Rider Feedback"}},"template--15213462618185__cdffcd03-a94b-4d6e-a504-1fe0b70347d6-heading-1":{"type":"heading","disabled":true,"settings":{"title":"","heading_max_width":15,"title_size":38,"title_size_mobile":20,"use_h1":true}},"text_ca3crW":{"type":"text","settings":{"text":"<p><em>Every Euphree ebike is built around one thing: how it actually feels to ride.<\/em><\/p>","enlarge_text":false}},"button_WLJ9C9":{"type":"button","disabled":true,"settings":{"button_label":"Explore Our Bikes","button_link":"shopify:\/\/collections\/electric-bikes","button_style":"primary"}}},"block_order":["template--15213462618185__cdffcd03-a94b-4d6e-a504-1fe0b70347d6-subheading-1","template--15213462618185__cdffcd03-a94b-4d6e-a504-1fe0b70347d6-heading-1","text_ca3crW","button_WLJ9C9"],"settings":{"image":"shopify:\/\/shop_images\/villagesgroupphoto.png","mobile_image":"shopify:\/\/shop_images\/VillageCycles.png","height":"adapt","height_desktop":720,"height_mobile":400,"image_link":"","full_width":true,"text_alignment":"center center","mobile_overlay_under":false,"overlay_style":"full image-overlay--bg-shadow"}},"ffca7f3f-a70e-4737-9485-80d1f269e72b":{"type":"rich-text","blocks":{"text_7bNDKi":{"type":"text","settings":{"text":"<p>I couldn’t find an ebike that felt truly comfortable, natural, and easy to trust, so we built one.<\/p>","enlarge_text":true}},"subheading_X3e4ph":{"type":"subheading","settings":{"subheading":"– Daniel, Founder & CEO"}}},"block_order":["text_7bNDKi","subheading_X3e4ph"],"settings":{"height":"medium","text_alignment":"center","full_width":false,"color_scheme":"default"}},"image_with_text_pPnR8C":{"type":"image-with-text","blocks":{"heading_UWenC8":{"type":"heading","disabled":true,"settings":{"title":"Image with text","use_h1":false}},"text_jQHDND":{"type":"text","settings":{"text":"<p>Most ebike companies chase flashy features. We take the opposite approach. Euphree was founded on one belief:<em>a truly great ride should feel effortless, sturdy, and joyful every single time.<\/em>That’s why every bike we make is upright, confidence-inspiring, and built from real rider feedback.<\/p>","enlarge_text":false}}},"block_order":["heading_UWenC8","text_jQHDND"],"name":"Image with text","settings":{"image":"shopify:\/\/shop_images\/Debbie_on_SolarSparrow_Americano.png","image_width":700,"image_link":"","image_position":"left","text_alignment":"left","color_scheme":"default"}},"multi_column_Yd4pFp":{"type":"multi-column","blocks":{"text_block_xhPD6H":{"type":"text_block","disabled":true,"settings":{"enable_media":true,"image":"shopify:\/\/shop_images\/Solar_Sparrow_Upright_Riding_Position_Detail.png","title":"Comfort-first Design","text":"<p>Upright riding position, dialed-in geometry, and plush suspension deliver a smooth, strain-free ride.<\/p>","button_label":"","link":""}},"text_block_Tr3ci8":{"type":"text_block","settings":{"enable_media":true,"image":"shopify:\/\/shop_images\/SGS_Certified.png","title":"SGS Certified for Safety & Performance","text":"<p>All Euphree bikes are SGSNA\/24\/CQ\/00032 certified to UL 2271 & UL 2849 standards for battery and electrical safety.<\/p>","button_label":"","link":""}},"text_block_egCKQm":{"type":"text_block","settings":{"enable_media":true,"image":"shopify:\/\/shop_images\/euphree_bike_shop.png","title":"Real USA Support","text":"<p>Based in Houston, Texas, our team answers the phone, guides you through setup, and stays with you beyond your first ride.<\/p>","button_label":"","link":"shopify:\/\/pages\/customer-support"}}},"block_order":["text_block_xhPD6H","text_block_Tr3ci8","text_block_egCKQm"],"name":"Multi-column","settings":{"title":"","media_aspect_ratio":"s","media_width":700,"text_alignment":"center","button_style":"primary","color_scheme":"default"}},"logo_list_3n8xtX":{"type":"logo-list","blocks":{"logo_87dBiC":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/Schwalbe_Logo_b19a9369-d2fc-4664-a7d4-34876ca4288a.svg","image_width":160,"link":"","title":""}},"logo_DnbmED":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/BAFICON.svg","image_width":160,"link":"","title":""}},"logo_KJrMCJ":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/LG_Electronics_Logo.svg","image_width":160,"link":"","title":""}},"logo_aXaDyw":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/Tektro_logo.svg","image_width":160,"link":"","title":""}},"logo_hiitwx":{"type":"logo","settings":{"image":"shopify:\/\/shop_images\/Shimicon.svg","image_width":160,"link":"","title":""}}},"block_order":["logo_87dBiC","logo_DnbmED","logo_KJrMCJ","logo_aXaDyw","logo_hiitwx"],"name":"Logo list","settings":{"title":"We only use brands mechanic approve","image_opacity":100,"color_scheme":"default"}},"featured_collection_tW7pRK":{"type":"featured-collection","name":"Featured collection","settings":{"title":"Discover our electric bikes","collection":"electric-bikes","show_vendor":false,"enable_carousel":true,"grid":4,"rows":1,"color_scheme":"default","show_view_all":true,"full_width":true}},"image_with_text_7wPa73":{"type":"image-with-text","blocks":{"heading_VLik3e":{"type":"heading","settings":{"title":"See the Difference Yourself","use_h1":true}},"text_JHfK6G":{"type":"text","settings":{"text":"<p><em>Visit one of our retail partners to experience the Euphree difference in person. Take a ride, ask questions, and feel how intuitive our bikes really are.<\/em><\/p>","enlarge_text":true}},"button_QQDUzH":{"type":"button","settings":{"button_label":"Find a Dealer Near You","button_link":"shopify:\/\/pages\/dealer-locator","button_style":"primary"}}},"block_order":["heading_VLik3e","text_JHfK6G","button_QQDUzH"],"name":"Image with text","settings":{"image":"shopify:\/\/shop_images\/hollywood_bike_shop_with_euphree.png","image_width":700,"image_link":"","image_position":"left","text_alignment":"left","color_scheme":"default"}},"key_features_ChPJ46":{"type":"key-features","blocks":{"feature_RGaJff":{"type":"feature","settings":{"image":"shopify:\/\/shop_images\/Stellar_Falcon_Front_Fork_Suspension_View.png","bg_color":"#ffffff","bg_gradient":"","text_color":"#1f1f1f","heading":"Fully Integrated Wiring for a Clean, Protected Look","text":"<p>Only Euphree hides cables within the frame, no dangling wires, no maintenance headaches. Looks sleek and protects components.<\/p>","show_segments":true,"segments":5,"active_segment":"4","fill_segments":true,"show_labels":true,"label_left":"","label_middle":"","label_right":"","show_icon":false,"icon":"star"}},"feature_VVfAhH":{"type":"feature","settings":{"image":"shopify:\/\/shop_images\/beltdrive_07b44b90-7609-42c4-8be9-c4df42a2047a.png","bg_color":"#ffffff","bg_gradient":"","text_color":"#1f1f1f","heading":"Smooth welds","text":"<p>Our frames feature ultra-smooth welds and seamless joints, finished with premium automotive-grade paint for a clean look and lasting strength.<\/p>","show_segments":true,"segments":5,"active_segment":"2","fill_segments":true,"show_labels":true,"label_left":"","label_middle":"","label_right":"","show_icon":false,"icon":"star"}},"feature_D6VzjE":{"type":"feature","settings":{"image":"shopify:\/\/shop_images\/CityRobinX_SeatpostSuspension.png","bg_color":"#ffffff","bg_gradient":"","text_color":"#1f1f1f","heading":"Complimentary Comfort Kit Included","text":"<p>Each model includes a cushioned wide saddle and a Seatpost Suspension because comfort, convenience, and quality should come standard, not optional.<\/p>","show_segments":true,"segments":5,"active_segment":"3","fill_segments":true,"show_labels":true,"label_left":"","label_middle":"","label_right":"","show_icon":false,"icon":"star"}}},"block_order":["feature_RGaJff","feature_VVfAhH","feature_D6VzjE"],"name":"Key features","settings":{"heading":"Why Riders Choose Euphree","image_max_width":700,"media_aspect_ratio":"1","image_position":"left","segment_position":"over-text"}},"image_with_text_overlay_teqp9G":{"type":"image-with-text-overlay","blocks":{"subheading_Gcc8QC":{"type":"subheading","settings":{"subheading":"Premium Components, No Shortcuts"}},"heading_T3q8Ea":{"type":"heading","settings":{"title":"Quality You Can Feel","heading_max_width":15,"title_size":58,"title_size_mobile":22,"use_h1":true}},"text_PQ8DT4":{"type":"text","settings":{"text":"<p>Euphree bikes are built using the same components we use on our own bikes. Shimano drivetrains, Schwalbe tires, Bafang systems, and LG battery cells. The result: a dependable, low-maintenance ebike that can handle real-world riding day after day.<\/p>","enlarge_text":true}}},"block_order":["subheading_Gcc8QC","heading_T3q8Ea","text_PQ8DT4"],"disabled":true,"name":"Image with text overlay","settings":{"image":"shopify:\/\/shop_images\/Americano_Close_up.png","height":"fixed","height_desktop":600,"height_mobile":460,"image_link":"","full_width":true,"text_alignment":"center center","mobile_overlay_under":false,"overlay_style":"full image-overlay--bg-shadow"}},"about_faq_section":{"type":"collapsible-tabs","blocks":{"q_where_based":{"type":"question","settings":{"title":"Where is Euphree based and how can I contact support?","answer":"<p>We are proudly USA-based. Our <a href='https:\/\/euphree.com\/pages\/customer-support'>Customer Support team<\/a> is available by phone, live chat, and email. You can also visit a local <a href='https:\/\/euphree.com\/pages\/dealer-locator'>Euphree dealer<\/a> for in-person assistance.<\/p>"}},"q_safety_cert":{"type":"question","settings":{"title":"Are Euphree electric bikes safety certified?","answer":"<p>Yes — all models are SGS-verified to meet <strong>UL 2849<\/strong> (full electrical system) and <strong>UL 2271<\/strong> (battery safety) standards. Certification ID: <strong>SGSNA\/24\/CQ\/00032<\/strong>.<\/p>"}},"q_warranty":{"type":"question","settings":{"title":"What warranty comes with my Euphree bike?","answer":"<p>Every Euphree ebike is backed by a <a href='https:\/\/euphree.com\/pages\/warranty'>2-year limited warranty<\/a> covering frame, electronics, and major components. This ensures long-term peace of mind for your purchase.<\/p>"}},"q_shipping_returns":{"type":"question","settings":{"title":"How does shipping and returns work?","answer":"<p>We ship directly to your door with most bikes arriving 95% assembled. For full details, visit our <a href='https:\/\/euphree.com\/pages\/returns'>Shipping & Returns<\/a> page.<\/p>"}},"q_app_required":{"type":"question","settings":{"title":"Do I need an app to ride my Euphree bike?","answer":"<p>No app is required — simply turn on your bike and ride. Our left-side color display makes it easy to adjust settings without a phone or login.<\/p>"}},"q_fit_sizing":{"type":"question","settings":{"title":"How do I know if a Euphree bike will fit me?","answer":"<p>Each model lists recommended rider height and key fit details on its product page. For hands-on sizing, schedule a test ride at a <a href='https:\/\/euphree.com\/pages\/dealer-locator'>local dealer<\/a>.<\/p>"}},"q_register":{"type":"question","settings":{"title":"Should I register my Euphree bike?","answer":"<p>Yes — registering your bike helps us provide faster support and confirms warranty coverage. Register here: <a href='https:\/\/euphree.com\/pages\/bike-registration'>Bike Registration<\/a>.<\/p>"}},"q_assembly_manuals":{"type":"question","settings":{"title":"Where can I find assembly instructions and manuals?","answer":"<p>We offer easy-to-follow assembly videos and downloadable manuals on our <a href='https:\/\/euphree.com\/pages\/assembly-manuals'>Assembly & Manuals<\/a> page.<\/p>"}}},"block_order":["q_where_based","q_safety_cert","q_warranty","q_shipping_returns","q_app_required","q_fit_sizing","q_register","q_assembly_manuals"],"settings":{"title":""}},"featured_blog_7igJyA":{"type":"featured-blog","disabled":true,"name":"Blog posts","settings":{"title":"Stay Updated","blog":"euphree-official-news-latest-press-releases-updates","post_limit":3,"show_author":false,"show_date":false,"show_excerpts":true,"crop_ratio":"1.78","color_scheme":"default"}},"collection_list_GQzVe6":{"type":"collection-list","disabled":true,"name":"Collection list","settings":{"title":"Collection list","enable_carousel":true,"grid":4,"color_scheme":"default","full_width":true,"coll_grid_image_shape":"square","coll_grid_image_position":"center center","coll_thumb_mob_per_row":"2","coll_grid_show_count":true,"coll_text_position":"below","coll_text_position_under_mobile":false,"coll_thumb_text_align_x":"center","coll_thumb_text_align_y":"center","coll_button_style":"primary"}},"newsletter_HNnxym":{"type":"newsletter","name":"Newsletter","settings":{"title":"Updates Built Around You","subheading":"<p>Subscribe for updates on accessories, safety tips, and stories from Euphree riders. <\/p>","color_scheme":"2"}},"custom_liquid_kxrdWX":{"type":"custom-liquid","name":"Custom Liquid","settings":{"full_width":true,"show_space":false,"code":"<!-- Elfsight Instagram Feed | Untitled Instagram Feed -->\n<script src=\"https:\/\/static.elfsight.com\/platform\/platform.js\" async><\/script>\n<div class=\"elfsight-app-d0859147-75ab-4c02-bf03-e2551ca43757\" data-elfsight-app-lazy><\/div>"}}},"order":["main","cdffcd03-a94b-4d6e-a504-1fe0b70347d6","ffca7f3f-a70e-4737-9485-80d1f269e72b","image_with_text_pPnR8C","multi_column_Yd4pFp","logo_list_3n8xtX","featured_collection_tW7pRK","image_with_text_7wPa73","key_features_ChPJ46","image_with_text_overlay_teqp9G","about_faq_section","featured_blog_7igJyA","collection_list_GQzVe6","newsletter_HNnxym","custom_liquid_kxrdWX"]}