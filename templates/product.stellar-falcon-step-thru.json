        "html_XYdynr": {
          "type": "html",
          "settings": {
            "width": "half",
            "code": "<!-- Begin Scoped Stellar Falcon Step-Thru Sizing -->\n<div id=\"stellar-stepthru-sizing\">\n  <div class=\"sizing-tabs\">\n    <button class=\"tab active\" data-target=\"stepthru\">Step-Thru</button>\n    <button class=\"tab\" data-target=\"compare\">Compare</button>\n  </div>\n\n  <!-- Step-Thru Only -->\n  <div class=\"sizing-content\" id=\"stepthru\">\n    <div class=\"sizing-photo\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0577/5346/9110/files/1_7b7dff38-2f81-4270-ac0e-6f7dd79d5785.png\" alt=\"Stellar Falcon Step-Thru Sizing Guide\">\n    </div>\n    <div class=\"sizing-table\">\n      <table>\n        <tbody>\n          <tr><td><strong>Customer Height</strong></td><td>5’2” – 6’0”</td></tr>\n          <tr><td><strong>Seat Tube Length</strong></td><td>15 in</td></tr>\n          <tr><td><strong>Total Length</strong></td><td>74 in</td></tr>\n          <tr><td><strong>Wheelbase</strong></td><td>48 in</td></tr>\n          <tr><td><strong>Standover Height</strong></td><td>18 in</td></tr>\n          <tr><td><strong>Reach</strong></td><td>17 in</td></tr>\n          <tr><td><strong>Saddle Height</strong></td><td>32 – 40 in</td></tr>\n          <tr><td><strong>Handlebar Height</strong></td><td>42 – 46 in (adjustable)</td></tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n\n  <!-- Compare Mode -->\n  <div class=\"sizing-content\" id=\"compare\" style=\"display: none;\">\n    <div class=\"compare-columns\">\n      <div class=\"compare-card\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0577/5346/9110/files/1_7b7dff38-2f81-4270-ac0e-6f7dd79d5785.png\" alt=\"Step-Thru Frame\">\n        <table>\n          <tr><td><strong>Customer Height</strong></td><td>5’2” – 6’0”</td></tr>\n          <tr><td><strong>Seat Tube</strong></td><td>15 in</td></tr>\n          <tr><td><strong>Standover</strong></td><td>18 in</td></tr>\n        </table>\n      </div>\n      <div class=\"compare-card\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0577/5346/9110/files/2_d0270288-59f3-41c5-9949-f8c75bc9559f.png\" alt=\"Mid-Step Frame\">\n        <table>\n          <tr><td><strong>Customer Height</strong></td><td>5’4” – 6’2”</td></tr>\n          <tr><td><strong>Seat Tube</strong></td><td>17 in</td></tr>\n          <tr><td><strong>Standover</strong></td><td>23.5 in</td></tr>\n        </table>\n      </div>\n    </div>\n  </div>\n</div>\n\n<style>\n  /* Scoped: Stellar Falcon Step-Thru Sizing */\n  #stellar-stepthru-sizing {\n    max-width: 700px;\n    margin: 0 auto;\n    font-family: inherit;\n    font-size: 0.95rem;\n    color: #2E2E2E;\n  }\n\n  /* Tabs */\n  #stellar-stepthru-sizing .sizing-tabs {\n    display: flex;\n    justify-content: center;\n    gap: 0.5rem;\n    margin-bottom: 1rem;\n  }\n\n  #stellar-stepthru-sizing .tab {\n    flex: 1;\n    padding: 0.6rem;\n    border-radius: 6px;\n    border: 1px solid #ccc;\n    background: #f9f9f9;\n    cursor: pointer;\n    font-weight: 600;\n    font-size: 0.9rem;\n    color: #333;\n  }\n\n  #stellar-stepthru-sizing .tab.active {\n    background: #2E2E2E;\n    color: #fff;\n    border-color: #2E2E2E;\n  }\n\n  /* Content Wrapper */\n  #stellar-stepthru-sizing .sizing-content {\n    text-align: center;\n  }\n\n  #stellar-stepthru-sizing .sizing-photo img {\n    width: 100%;\n    max-width: 500px;\n    border-radius: 6px 6px 0 0;\n    margin: 0;\n    display: block;\n  }\n\n  /* Table */\n  #stellar-stepthru-sizing .sizing-table table,\n  #stellar-stepthru-sizing .compare-card table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 0.95rem;\n  }\n\n  #stellar-stepthru-sizing td {\n    border: 1px solid #ddd;\n    padding: 8px 10px;\n    text-align: left;\n    line-height: 1.4;\n  }\n\n  #stellar-stepthru-sizing tr:nth-child(even) {\n    background-color: #f9f9f9;\n  }\n\n  /* Compare Layout */\n  #stellar-stepthru-sizing .compare-columns {\n    display: flex;\n    flex-direction: column;\n    gap: 1.5rem;\n  }\n\n  #stellar-stepthru-sizing .compare-card {\n    flex: 1;\n    background: #fff;\n    border: 1px solid #ddd;\n    border-radius: 6px;\n    overflow: hidden;\n  }\n\n  #stellar-stepthru-sizing .compare-card img {\n    width: 100%;\n    max-height: 250px;\n    object-fit: contain;\n    display: block;\n    border-bottom: 1px solid #ddd;\n  }\n\n  @media (min-width: 768px) {\n    #stellar-stepthru-sizing .compare-columns {\n      flex-direction: row;\n    }\n  }\n</style>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const wrapper = document.querySelector(\"#stellar-stepthru-sizing\");\n    if (!wrapper) return;\n    const buttons = wrapper.querySelectorAll(\".tab\");\n    const contents = {\n      stepthru: wrapper.querySelector(\"#stepthru\"),\n      compare: wrapper.querySelector(\"#compare\"),\n    };\n\n    buttons.forEach((btn) => {\n      btn.addEventListener(\"click\", () => {\n        buttons.forEach((b) => b.classList.remove(\"active\"));\n        btn.classList.add(\"active\");\n\n        Object.values(contents).forEach((c) => (c.style.display = \"none\"));\n        contents[btn.dataset.target].style.display = \"block\";\n      });\n    });\n  });\n</script>\n<!-- End Scoped Stellar Falcon Step-Thru Sizing -->"
          }
        }
      },
