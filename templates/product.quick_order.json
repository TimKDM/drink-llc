        "collapsible_row_1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Are drink Ingredients products organic?",
            "icon": "question_mark",
            "row_content": "<p>Yes, all drink Ingredients products are USDA certified organic. We source only from farms that meet strict organic standards, ensuring every ingredient is free from synthetic pesticides, herbicides, and GMOs.</p>",
            "page": ""
          }
        },
        "collapsible_row_2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Where do you source your ingredients?",
            "icon": "question_mark",
            "row_content": "<p>We partner directly with certified organic farms around the world. Our ingredients are sourced through direct farm partnerships, ensuring traceability, fair trade practices, and the highest quality from origin to your kitchen.</p>",
            "page": ""
          }
        },
        "collapsible_row_3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Do you offer bulk or wholesale pricing?",
            "icon": "question_mark",
            "row_content": "<p>Yes! We offer wholesale pricing for cafés, restaurants, wellness brands, and food manufacturers. Contact our team for custom bulk quotes and dedicated account support.</p>",
            "page": ""
          }
        },
        "collapsible_row_4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How do you ensure product quality?",
            "icon": "check_mark",
            "row_content": "<p>Every batch of our products undergoes independent third-party lab testing for purity, potency, and allergen safety. We maintain rigorous quality control from sourcing through packaging to ensure consistent excellence.</p>",
            "page": ""
          }
        },
        "collapsible_row_5": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Are there any additives in your products?",
            "icon": "check_mark",
            "row_content": "<p>Absolutely not. We maintain a strict zero additives policy. Our products contain no synthetic fillers, artificial colors, flavors, or preservatives — just pure, clean ingredients as nature intended.</p>",
            "page": ""
          }
        }
