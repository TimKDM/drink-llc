{%- comment -%} Drink LLC — Cart Template {%- endcomment -%}

<div class="section">
  <div class="container container--narrow">
    <h1>Cart</h1>

    {%- if cart.item_count > 0 -%}
      <form action="/cart" method="post" class="cart-form">
        <div class="cart-items">
          {%- for item in cart.items -%}
            <div class="cart-item">
              <div class="cart-item__image">
                {%- if item.image -%}
                  <img
                    src="{{ item.image | image_url: width: 200 }}"
                    alt="{{ item.title | escape }}"
                    width="100"
                    height="100"
                    loading="lazy"
                  >
                {%- endif -%}
              </div>

              <div class="cart-item__info">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                {%- if item.variant.title != 'Default Title' -%}
                  <span class="label">{{ item.variant.title }}</span>
                {%- endif -%}
                <p class="cart-item__price">{{ item.price | money }}</p>
              </div>

              <div class="cart-item__quantity">
                <label class="visually-hidden" for="quantity-{{ item.key }}">Quantity</label>
                <input
                  type="number"
                  name="updates[]"
                  id="quantity-{{ item.key }}"
                  value="{{ item.quantity }}"
                  min="0"
                  max="10"
                  aria-label="Quantity for {{ item.title }}"
                >
              </div>

              <div class="cart-item__total">
                <p>{{ item.line_price | money }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="cart-footer">
          <div class="cart-footer__subtotal">
            <span class="label">Subtotal</span>
            <span class="cart-footer__price">{{ cart.total_price | money }}</span>
          </div>
          <p class="cart-footer__note">Shipping calculated at checkout.</p>
          <div class="cart-footer__actions">
            <button type="submit" name="update" class="btn btn--secondary">Update</button>
            <button type="submit" name="checkout" class="btn btn--primary">Checkout</button>
          </div>
        </div>
      </form>
    {%- else -%}
      <div class="cart-empty">
        <p>{{ settings.cart_empty_message | default: 'Nothing here yet.' }}</p>
        <a href="/collections/all" class="btn btn--primary">Browse Drinks</a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .cart-form {
    margin-top: var(--space-xl);
  }

  .cart-item {
    display: grid;
    grid-template-columns: 100px 1fr auto auto;
    gap: var(--space-lg);
    align-items: center;
    padding: var(--space-lg) 0;
    border-bottom: 0.5px solid var(--color-carbon);
  }

  @media (max-width: 768px) {
    .cart-item {
      grid-template-columns: 80px 1fr;
      gap: var(--space-md);
    }

    .cart-item__quantity,
    .cart-item__total {
      grid-column: 2;
    }
  }

  .cart-item__image img {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    background-color: var(--color-carbon);
  }

  .cart-item__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .cart-item__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .cart-item__price {
    color: var(--color-ash);
    font-size: 0.9rem;
  }

  .cart-item__quantity input {
    width: 64px;
    text-align: center;
  }

  .cart-item__total p {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-offwhite);
    letter-spacing: 0.06em;
  }

  .cart-footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 0.5px solid var(--color-carbon);
    text-align: right;
  }

  .cart-footer__subtotal {
    display: flex;
    justify-content: flex-end;
    align-items: baseline;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .cart-footer__price {
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: 0.06em;
    color: var(--color-offwhite);
  }

  .cart-footer__note {
    font-size: 0.85rem;
    margin-bottom: var(--space-lg);
    margin-left: auto;
  }

  .cart-footer__actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-md);
  }

  .cart-empty {
    text-align: center;
    padding: var(--space-3xl) 0;
  }

  .cart-empty p {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ash);
    margin: 0 auto var(--space-lg);
  }
</style>
