{%- comment -%}
  Drink LLC — Product Card Snippet
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

{%- assign flavor_handle = product.handle | downcase -%}
{%- assign card_accent = '' -%}

{%- case flavor_handle -%}
  {%- when 'lemonade-drink' -%}
    {%- assign card_accent = '#FFE566' -%}
  {%- when 'lychee-drink' -%}
    {%- assign card_accent = '#FF9EBA' -%}
  {%- when 'peach-mango-drink' -%}
    {%- assign card_accent = '#FF8C42' -%}
  {%- when 'passion-fruit-drink' -%}
    {%- assign card_accent = '#C77DFF' -%}
  {%- when 'matcha-drink' -%}
    {%- assign card_accent = '#7CB518' -%}
{%- endcase -%}

<a href="{{ product.url }}" class="product-card" {% if card_accent != '' %}style="--card-accent: {{ card_accent }};"{% endif %}>
  <div class="product-card__media">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 600 }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="600"
        height="600"
        loading="lazy"
      >
    {%- else -%}
      <div class="product-card__placeholder">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    {%- endif -%}

    {%- unless product.available -%}
      <span class="badge product-card__badge" style="background-color: var(--color-ash);">Sold Out</span>
    {%- endunless -%}
  </div>

  <div class="product-card__info">
    <span class="drink-mono-label">{{ product.type | default: 'Hydration' }}</span>
    <h3 class="product-card__title">{{ product.title }}</h3>
    <p class="product-card__price">{{ product.price | money }}</p>
  </div>
</a>

<style>
  .product-card {
    display: block;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .product-card:hover {
    opacity: 0.9;
  }

  .product-card__media {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: var(--radius-md);
    background-color: var(--drink-bg-cream);
    margin-bottom: 16px;
    border: 1px solid var(--drink-sepia);
  }

  .product-card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 24px;
    transition: transform 0.4s ease;
  }

  .product-card:hover .product-card__media img {
    transform: scale(1.05);
  }

  .product-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-card__placeholder svg {
    width: 40%;
    opacity: 0.2;
  }

  .product-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    background: var(--drink-rust);
    color: #fff;
    padding: 2px 8px;
  }

  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .product-card__title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    color: var(--drink-black);
    margin: 0;
  }

  .product-card__price {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1rem;
    color: var(--drink-rust);
    margin: 0;
  }
</style>
